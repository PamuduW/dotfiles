#!/usr/bin/env bash
set -euo pipefail

_script="$(readlink -f "${BASH_SOURCE[0]}")"
DOTFILES_DIR="$(dirname "$(dirname "$(dirname "$_script")")")"

_REPORT_TABLE_LIB="${DOTFILES_DIR}/scripts/lib/report_table.sh"
if [[ -f "$_REPORT_TABLE_LIB" ]]; then
	# shellcheck source=/dev/null
	source "$_REPORT_TABLE_LIB"
fi

_dotfiles_tui_mode() {
	[[ -n "${DOTFILES_TUI:-}" ]]
}

# --- TTY colors ---
_dotfiles_use_color() {
	[[ -n "${NO_COLOR:-}" ]] && return 1
	[[ -n "${FORCE_COLOR:-}" ]] && return 0
	[[ -t 1 ]] && return 0
	# install.sh tees stdout to a log; stdin stays on the real terminal.
	[[ -t 0 ]] && return 0
	return 1
}

if _dotfiles_use_color; then
	C_RESET=$'\033[0m'
	C_BOLD=$'\033[1m'
	C_DIM=$'\033[2m'
	C_GREEN=$'\033[32m'
	C_YELLOW=$'\033[33m'
	C_CYAN=$'\033[36m'
	C_RED=$'\033[31m'
else
	C_RESET=''
	C_BOLD=''
	C_DIM=''
	C_GREEN=''
	C_YELLOW=''
	C_CYAN=''
	C_RED=''
fi

NOT_INSTALLED='not installed'

# --- Helpers ---
_msg() { printf '%s\n' "$*"; }
_warn() { printf '%s%s%s\n' "$C_YELLOW" "$*" "$C_RESET" >&2; }
_err() { printf '%s%s%s\n' "$C_RED" "$*" "$C_RESET" >&2; }

declare -A UPGRADE_STEP_RESULT=()

_run_upgrade_step() {
	local label="$1"
	shift
	printf '\n%s=== %s ===%s\n' "$C_BOLD" "$label" "$C_RESET"
	set +e
	"$@"
	local rc=$?
	set -e
	if [[ $rc -ne 0 ]]; then
		_warn "  ${label} failed (exit ${rc})"
		UPGRADE_STEP_RESULT["$label"]="failed"
	else
		UPGRADE_STEP_RESULT["$label"]="ok"
	fi
}

_github_latest_version() {
	local repo="$1"
	command -v curl >/dev/null 2>&1 || return 1
	curl -fsSL "https://api.github.com/repos/${repo}/releases/latest" 2>/dev/null |
		grep -Po '"tag_name":\s*"v\K[^"]*' | head -n1
}

_version_gt() {
	# Returns 0 if $1 > $2 (sort -V)
	[[ "$(printf '%s\n%s\n' "$2" "$1" | sort -V | tail -n1)" == "$1" && "$1" != "$2" ]]
}

# Verify tarball SHA256 appears in a GitHub release checksums.txt (filename-agnostic).
_verify_github_tarball_checksum() {
	local dir="$1" tarball="$2" checksums_file="$3"
	local actual

	[[ -f "$dir/$tarball" && -f "$dir/$checksums_file" ]] || return 1
	actual="$(sha256sum "$dir/$tarball" | awk '{print $1}')"
	grep -qF "$actual" "$dir/$checksums_file"
}

_load_nvm() {
	local nvm_dir="${NVM_DIR:-$HOME/.nvm}"
	# shellcheck source=/dev/null
	[[ -s "${nvm_dir}/nvm.sh" ]] && . "${nvm_dir}/nvm.sh"
}

# --- apt ---
apt_upgradable_count() {
	if ! command -v apt-get >/dev/null 2>&1; then
		echo 0
		return
	fi
	local count
	count="$(apt-get -s upgrade 2>/dev/null | grep -c '^Inst' || true)"
	echo "${count:-0}"
}

check_apt() {
	local count installed available action upgradable=0
	count="$(apt_upgradable_count)"
	if command -v apt-get >/dev/null 2>&1; then
		installed="system packages"
	else
		installed="$NOT_INSTALLED"
	fi
	if [[ "$count" -gt 0 ]]; then
		available="${count} package(s)"
		action="upgrade"
		upgradable=1
	else
		available="none"
		action="up to date"
	fi
	printf '%s|%s|%s|%s\n' "apt packages" "$installed" "$available" "$action"
	[[ $upgradable -eq 1 ]]
}

upgrade_apt() {
	if ! command -v apt-get >/dev/null 2>&1; then
		_warn "apt-get not found, skipping apt upgrade"
		return 0
	fi
	sudo apt-get update -qq && sudo apt-get -o Dpkg::Use-Pty=0 upgrade -y
}

# --- Cursor CLI ---
cursor_installed_version() {
	if command -v agent >/dev/null 2>&1; then
		agent --version 2>/dev/null | head -n1 || echo "installed"
	elif command -v cursor >/dev/null 2>&1; then
		cursor --version 2>/dev/null | head -n1 || echo "installed"
	else
		echo "$NOT_INSTALLED"
	fi
}

cursor_is_installed() {
	command -v agent >/dev/null 2>&1 || command -v cursor >/dev/null 2>&1
}

check_cursor_cli() {
	local installed available action upgradable=0
	installed="$(cursor_installed_version)"
	if cursor_is_installed; then
		if command -v agent >/dev/null 2>&1; then
			available="latest (via agent update)"
		else
			available="latest (via cursor update)"
		fi
		action="refresh"
		upgradable=1
	else
		available="—"
		action="skip"
	fi
	printf '%s|%s|%s|%s\n' "Cursor CLI" "$installed" "$available" "$action"
	[[ $upgradable -eq 1 ]]
}

upgrade_cursor_cli() {
	if command -v agent >/dev/null 2>&1; then
		agent update
	elif command -v cursor >/dev/null 2>&1; then
		cursor update
	else
		_msg "  Cursor CLI not installed, skipping"
	fi
}

# --- Codex CLI ---
codex_installed_version() {
	_load_nvm
	if command -v codex >/dev/null 2>&1; then
		codex --version 2>/dev/null | head -n1 || echo "installed"
	else
		echo "$NOT_INSTALLED"
	fi
}

codex_available_version() {
	if ! command -v npm >/dev/null 2>&1; then
		echo "—"
		return
	fi
	npm view @openai/codex version 2>/dev/null || echo "—"
}

check_codex_cli() {
	local installed available action upgradable=0
	installed="$(codex_installed_version)"
	if [[ "$installed" == "$NOT_INSTALLED" ]]; then
		available="—"
		action="skip"
	else
		available="$(codex_available_version)"
		if [[ "$available" != "—" && "$installed" != *"${available}"* ]]; then
			action="upgrade"
		else
			action="refresh"
		fi
		upgradable=1
	fi
	printf '%s|%s|%s|%s\n' "Codex CLI" "$installed" "$available" "$action"
	[[ $upgradable -eq 1 ]]
}

upgrade_codex_cli() {
	_load_nvm
	if command -v codex >/dev/null 2>&1 && command -v npm >/dev/null 2>&1; then
		npm i -g @openai/codex@latest
	else
		_msg "  Codex CLI or npm not installed, skipping"
	fi
}

# --- Claude CLI ---
claude_installed_version() {
	if command -v claude >/dev/null 2>&1; then
		claude --version 2>/dev/null | head -n1 || echo "installed"
	else
		echo "$NOT_INSTALLED"
	fi
}

check_claude_cli() {
	local installed available action upgradable=0
	installed="$(claude_installed_version)"
	if [[ "$installed" == "$NOT_INSTALLED" ]]; then
		available="—"
		action="skip"
	else
		available="latest (via claude update)"
		action="refresh"
		upgradable=1
	fi
	printf '%s|%s|%s|%s\n' "Claude CLI" "$installed" "$available" "$action"
	[[ $upgradable -eq 1 ]]
}

upgrade_claude_cli() {
	if command -v claude >/dev/null 2>&1; then
		claude update
	else
		_msg "  Claude CLI not installed, skipping"
	fi
}

# --- Copilot CLI ---
copilot_installed_version() {
	if command -v copilot >/dev/null 2>&1; then
		copilot --version 2>/dev/null | head -n1 || echo "installed"
	elif [[ -x "$HOME/.local/bin/copilot" ]]; then
		"$HOME/.local/bin/copilot" --version 2>/dev/null | head -n1 || echo "installed"
	else
		echo "$NOT_INSTALLED"
	fi
}

copilot_is_installed() {
	command -v copilot >/dev/null 2>&1 || [[ -x "$HOME/.local/bin/copilot" ]]
}

check_copilot_cli() {
	local installed available action upgradable=0
	installed="$(copilot_installed_version)"
	if copilot_is_installed; then
		available="latest (via copilot update)"
		action="refresh"
		upgradable=1
	else
		available="—"
		action="skip"
	fi
	printf '%s|%s|%s|%s\n' "Copilot CLI" "$installed" "$available" "$action"
	[[ $upgradable -eq 1 ]]
}

upgrade_copilot_cli() {
	if copilot_is_installed; then
		copilot update
	else
		_msg "  Copilot CLI not installed, skipping"
	fi
}

# --- lazygit ---
lazygit_installed_version() {
	if command -v lazygit >/dev/null 2>&1; then
		lazygit --version 2>/dev/null | grep -oP 'version=\K[0-9.]+' | head -n1 ||
			lazygit --version 2>/dev/null | head -n1 || echo "installed"
	else
		echo "$NOT_INSTALLED"
	fi
}

check_lazygit() {
	local installed latest available action upgradable=0
	installed="$(lazygit_installed_version)"
	if [[ "$installed" == "$NOT_INSTALLED" ]]; then
		available="—"
		action="skip"
	else
		latest="$(_github_latest_version jesseduffield/lazygit || true)"
		available="${latest:-unknown}"
		if [[ -n "$latest" ]] && _version_gt "$latest" "$installed"; then
			action="upgrade"
			upgradable=1
		else
			action="up to date"
		fi
	fi
	printf '%s|%s|%s|%s\n' "lazygit" "$installed" "$available" "$action"
	[[ $upgradable -eq 1 ]]
}

install_lazygit_from_github() {
	command -v curl >/dev/null 2>&1 || {
		_err "  curl required for lazygit install."
		return 1
	}
	command -v tar >/dev/null 2>&1 || {
		_err "  tar required for lazygit install."
		return 1
	}

	local ver tmp
	ver="$(_github_latest_version jesseduffield/lazygit)"
	[[ -n "$ver" ]] || {
		_err "  Could not determine lazygit version."
		return 1
	}

	tmp="$(mktemp -d)"
	trap "rm -rf '${tmp}'" RETURN
	local tarball="lazygit_${ver}_Linux_x86_64.tar.gz"
	curl -fsSL -o "$tmp/$tarball" \
		"https://github.com/jesseduffield/lazygit/releases/download/v${ver}/${tarball}"
	curl -fsSL -o "$tmp/checksums.txt" \
		"https://github.com/jesseduffield/lazygit/releases/download/v${ver}/checksums.txt"
	if ! _verify_github_tarball_checksum "$tmp" "$tarball" checksums.txt; then
		_err "  lazygit checksum verification failed."
		return 1
	fi
	tar -C "$tmp" -xzf "$tmp/$tarball" lazygit
	sudo install -m 0755 "$tmp/lazygit" /usr/local/bin/lazygit
	rm -rf "$tmp"
	trap - RETURN
	_msg "  lazygit v${ver} installed"
}

upgrade_lazygit() {
	if ! command -v lazygit >/dev/null 2>&1; then
		_msg "  lazygit not installed, skipping"
		return 0
	fi
	local installed latest
	installed="$(lazygit_installed_version)"
	latest="$(_github_latest_version jesseduffield/lazygit || true)"
	if [[ -n "$latest" && -n "$installed" ]] && _version_gt "$latest" "$installed"; then
		install_lazygit_from_github
	else
		_msg "  lazygit already up to date (${installed})"
	fi
}

# --- lazydocker ---
lazydocker_installed_version() {
	if command -v lazydocker >/dev/null 2>&1; then
		lazydocker --version 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -n1 ||
			echo "$NOT_INSTALLED"
	else
		echo "$NOT_INSTALLED"
	fi
}

check_lazydocker() {
	local installed latest available action upgradable=0
	installed="$(lazydocker_installed_version)"
	if [[ "$installed" == "$NOT_INSTALLED" ]]; then
		available="—"
		action="skip"
	else
		latest="$(_github_latest_version jesseduffield/lazydocker || true)"
		available="${latest:-unknown}"
		if [[ -n "$latest" ]] && _version_gt "$latest" "$installed"; then
			action="upgrade"
			upgradable=1
		else
			action="up to date"
		fi
	fi
	printf '%s|%s|%s|%s\n' "lazydocker" "$installed" "$available" "$action"
	[[ $upgradable -eq 1 ]]
}

install_lazydocker_from_github() {
	command -v curl >/dev/null 2>&1 || {
		_err "  curl required for lazydocker install."
		return 1
	}
	command -v tar >/dev/null 2>&1 || {
		_err "  tar required for lazydocker install."
		return 1
	}

	local ver tmp
	ver="$(_github_latest_version jesseduffield/lazydocker)"
	[[ -n "$ver" ]] || {
		_err "  Could not determine lazydocker version."
		return 1
	}

	tmp="$(mktemp -d)"
	trap "rm -rf '${tmp}'" RETURN
	local tarball="lazydocker_${ver}_Linux_x86_64.tar.gz"
	curl -fsSL -o "$tmp/$tarball" \
		"https://github.com/jesseduffield/lazydocker/releases/download/v${ver}/${tarball}"
	curl -fsSL -o "$tmp/checksums.txt" \
		"https://github.com/jesseduffield/lazydocker/releases/download/v${ver}/checksums.txt"
	if ! _verify_github_tarball_checksum "$tmp" "$tarball" checksums.txt; then
		_err "  lazydocker checksum verification failed."
		return 1
	fi
	tar -C "$tmp" -xzf "$tmp/$tarball"

	if [[ ! -f "$tmp/lazydocker" ]]; then
		local binpath
		binpath="$(find "$tmp" -maxdepth 3 -type f -name lazydocker | head -n1 || true)"
		[[ -n "$binpath" ]] && cp "$binpath" "$tmp/lazydocker"
	fi

	sudo install -m 0755 "$tmp/lazydocker" /usr/local/bin/lazydocker
	rm -rf "$tmp"
	trap - RETURN
	_msg "  lazydocker v${ver} installed"
}

upgrade_lazydocker() {
	if ! command -v lazydocker >/dev/null 2>&1; then
		_msg "  lazydocker not installed, skipping"
		return 0
	fi
	local installed latest
	installed="$(lazydocker_installed_version)"
	latest="$(_github_latest_version jesseduffield/lazydocker || true)"
	if [[ -n "$latest" && -n "$installed" ]] && _version_gt "$latest" "$installed"; then
		install_lazydocker_from_github
	else
		_msg "  lazydocker already up to date (${installed})"
	fi
}

# --- Node.js (nvm) — opt-in ---
node_installed_version() {
	_load_nvm
	if command -v node >/dev/null 2>&1; then
		node --version 2>/dev/null | tr -d 'v'
	else
		echo "$NOT_INSTALLED"
	fi
}

node_lts_version() {
	_load_nvm
	if command -v nvm >/dev/null 2>&1; then
		nvm version-remote --lts 2>/dev/null | tr -d 'v' || echo "—"
	else
		echo "—"
	fi
}

check_node() {
	local installed available action upgradable=0
	installed="$(node_installed_version)"
	available="$(node_lts_version)"
	if [[ "$installed" == "$NOT_INSTALLED" ]]; then
		action="skip"
	elif [[ "$available" != "—" ]] && _version_gt "$available" "$installed"; then
		action="upgrade (--all)"
		upgradable=1
	else
		action="up to date"
	fi
	printf '%s|%s|%s|%s\n' "Node.js (nvm)" "$installed" "$available" "$action"
	[[ $upgradable -eq 1 ]]
}

upgrade_node() {
	_load_nvm
	if ! command -v nvm >/dev/null 2>&1; then
		_msg "  nvm not installed, skipping Node.js upgrade"
		return 0
	fi
	nvm install --lts
	nvm alias default 'lts/*'
}

# --- Go (asdf) — opt-in ---
go_installed_version() {
	if command -v asdf >/dev/null 2>&1; then
		local ver
		ver="$(asdf current golang 2>/dev/null | awk '$1=="golang" {print $2; exit}')"
		if [[ -n "$ver" ]]; then
			echo "$ver"
		else
			echo "$NOT_INSTALLED"
		fi
	elif command -v go >/dev/null 2>&1; then
		go version 2>/dev/null | grep -oP 'go\K[0-9.]+' | head -n1 || echo "installed"
	else
		echo "$NOT_INSTALLED"
	fi
}

go_latest_version() {
	if command -v asdf >/dev/null 2>&1; then
		asdf latest golang 2>/dev/null || echo "—"
	else
		echo "—"
	fi
}

check_go() {
	local installed available action upgradable=0
	installed="$(go_installed_version)"
	available="$(go_latest_version)"
	if [[ "$installed" == "$NOT_INSTALLED" ]]; then
		action="skip"
	elif [[ "$available" != "—" ]] && _version_gt "$available" "$installed"; then
		action="upgrade (--all)"
		upgradable=1
	else
		action="up to date"
	fi
	printf '%s|%s|%s|%s\n' "Go (asdf)" "$installed" "$available" "$action"
	[[ $upgradable -eq 1 ]]
}

upgrade_go() {
	if ! command -v asdf >/dev/null 2>&1; then
		_msg "  asdf not installed, skipping Go upgrade"
		return 0
	fi
	asdf install golang latest
	asdf set -u golang latest
	asdf reshim golang 2>/dev/null || true
}

# --- Monaspace fonts — opt-in ---
monaspace_installed_version() {
	local font_dir="$HOME/.local/share/fonts/monaspace"
	if [[ -d "$font_dir" ]] && compgen -G "${font_dir}/*.otf" >/dev/null 2>&1; then
		if [[ -f "${font_dir}/.version" ]]; then
			cat "${font_dir}/.version"
		else
			echo "installed"
		fi
	else
		echo "$NOT_INSTALLED"
	fi
}

monaspace_latest_version() {
	_github_latest_version githubnext/monaspace || echo "—"
}

check_monaspace() {
	local installed available action upgradable=0
	installed="$(monaspace_installed_version)"
	available="$(monaspace_latest_version)"
	if [[ "$installed" == "$NOT_INSTALLED" ]]; then
		action="skip"
	elif [[ "$available" != "—" && "$installed" != "$available" ]]; then
		action="upgrade (--all)"
		upgradable=1
	else
		action="up to date"
	fi
	printf '%s|%s|%s|%s\n' "Monaspace fonts" "$installed" "$available" "$action"
	[[ $upgradable -eq 1 ]]
}

install_monaspace_fonts() {
	local font_dir="$HOME/.local/share/fonts/monaspace"
	command -v curl >/dev/null 2>&1 || {
		_err "  curl required for Monaspace install."
		return 1
	}
	command -v unzip >/dev/null 2>&1 || {
		_err "  unzip required for Monaspace install."
		return 1
	}

	local ver tmp
	ver="$(monaspace_latest_version)"
	[[ -n "$ver" && "$ver" != "—" ]] || {
		_err "  Could not determine Monaspace version."
		return 1
	}

	tmp="$(mktemp -d)"
	trap "rm -rf '${tmp}'" RETURN
	local zip="monaspace-nerdfonts-v${ver}.zip"
	local url="https://github.com/githubnext/monaspace/releases/download/v${ver}/${zip}"
	if ! curl -fsSL -o "$tmp/monaspace-nerdfonts.zip" "$url"; then
		_err "  Monaspace download failed (${url})."
		return 1
	fi
	if ! unzip -qo "$tmp/monaspace-nerdfonts.zip" -d "$tmp/monaspace"; then
		_err "  Monaspace unzip failed."
		return 1
	fi

	mkdir -p "$font_dir"
	local otf_count=0
	while IFS= read -r -d '' otf; do
		cp "$otf" "$font_dir/"
		otf_count=$((otf_count + 1))
	done < <(find "$tmp/monaspace" -name '*.otf' -print0)
	if [[ $otf_count -eq 0 ]]; then
		_err "  No .otf files found in Monaspace archive."
		return 1
	fi
	printf '%s\n' "$ver" >"${font_dir}/.version"

	fc-cache -f 2>/dev/null || true
	rm -rf "$tmp"
	trap - RETURN
	_msg "  Monaspace Nerd Fonts ${ver} installed"
}

upgrade_monaspace() {
	install_monaspace_fonts
}

# --- dotfiles repo ---
dotfiles_repo_status() {
	if ! command -v git >/dev/null 2>&1; then
		echo "$NOT_INSTALLED|—|skip"
		return
	fi
	local branch local_rev remote_rev behind=0
	branch="$(git -C "$DOTFILES_DIR" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")"
	local_rev="$(git -C "$DOTFILES_DIR" rev-parse --short HEAD 2>/dev/null || echo "unknown")"
	remote_rev="$(git -C "$DOTFILES_DIR" ls-remote --heads origin "$branch" 2>/dev/null | awk '{print $1}' | head -n1)"
	local installed="${branch}@${local_rev}"
	local available="—"
	local action="up to date"
	if [[ -n "$remote_rev" && "$remote_rev" != "$(git -C "$DOTFILES_DIR" rev-parse HEAD 2>/dev/null)" ]]; then
		behind="$(git -C "$DOTFILES_DIR" rev-list --count HEAD.."origin/${branch}" 2>/dev/null || echo "?")"
		if [[ "$behind" == "?" ]]; then
			available="update on origin"
		else
			available="${behind} commit(s) behind"
		fi
		action="pull + restow"
	fi
	printf '%s|%s|%s|%s\n' "dotfiles repo" "$installed" "$available" "$action"
	[[ "$action" != "up to date" ]]
}

# --- Report helpers ---
CHECK_FUNCS=(
	check_apt
	check_cursor_cli
	check_codex_cli
	check_claude_cli
	check_copilot_cli
	check_lazygit
	check_lazydocker
	check_node
	check_go
	check_monaspace
	dotfiles_repo_status
)

_color_action() {
	local action="$1"
	case "$action" in
	up\ to\ date | skip) printf '%s%s%s' "$C_GREEN" "$action" "$C_RESET" ;;
	upgrade* | refresh) printf '%s%s%s' "$C_YELLOW" "$action" "$C_RESET" ;;
	pull*) printf '%s%s%s' "$C_CYAN" "$action" "$C_RESET" ;;
	*) printf '%s' "$action" ;;
	esac
}

_color_result() {
	local result="$1"
	case "$result" in
	ok | installed | configured) printf '%s%s%s' "$C_GREEN" "$result" "$C_RESET" ;;
	missing | failed) printf '%s%s%s' "$C_RED" "$result" "$C_RESET" ;;
	check | drift | extra) printf '%s%s%s' "$C_YELLOW" "$result" "$C_RESET" ;;
	skipped*) printf '%s%s%s' "$C_DIM" "$result" "$C_RESET" ;;
	*) printf '%s' "$result" ;;
	esac
}

# Color a numeric status cell: 0 stays green, non-zero uses severity.
# Optional width right-pads the digits before applying color (ANSI-safe).
_color_count() {
	local n="$1"
	local severity="${2:-warn}"
	local width="${3:-0}"
	local text="$n"

	if [[ "$width" -gt 0 ]]; then
		printf -v text "%${width}s" "$n"
	fi

	if [[ "$n" -eq 0 ]]; then
		printf '%s%s%s' "$C_GREEN" "$text" "$C_RESET"
		return
	fi
	case "$severity" in
	err) printf '%s%s%s' "$C_RED" "$text" "$C_RESET" ;;
	warn) printf '%s%s%s' "$C_YELLOW" "$text" "$C_RESET" ;;
	*) printf '%s' "$text" ;;
	esac
}

_collect_check_rows() {
	_load_nvm
	local -a rows=()
	local fn row
	for fn in "${CHECK_FUNCS[@]}"; do
		row="$("$fn" || true)"
		rows+=("$row")
	done
	printf '%s\n' "${rows[@]}"
}

# Fixed-width table row: truncate text columns so pipes stay aligned; color last column only.
_print_check_table_row() {
	local component="$1"
	local installed="$2"
	local available="$3"
	local last_col="$4"
	local color_fn="$5"

	printf '%-18.18s | %-28.28s | %-22.22s | ' "$component" "$installed" "$available"
	case "$color_fn" in
	result) _color_result "$last_col" ;;
	*) _color_action "$last_col" ;;
	esac
	printf '\n'
}

print_report_table() {
	local -a rows=()
	local row component installed available action
	local upgrade_count=0

	mapfile -t rows < <(_collect_check_rows)

	for row in "${rows[@]}"; do
		IFS='|' read -r _ _ _ action <<<"$row"
		case "$action" in
		upgrade | upgrade* | refresh) ((++upgrade_count)) ;;
		esac
	done

	printf '\n%sUpgrade report%s\n' "$C_BOLD" "$C_RESET"
	printf '%-18s | %-28s | %-22s | %s\n' "component" "installed" "available" "action"
	printf '%s\n' "-------------------+------------------------------+------------------------+----------"

	for row in "${rows[@]}"; do
		IFS='|' read -r component installed available action <<<"$row"
		_print_check_table_row "$component" "$installed" "$available" "$action" action
	done

	printf '\n'
	if [[ $upgrade_count -eq 0 ]]; then
		printf '%s0 upgrades available%s — everything looks current.\n' "$C_GREEN" "$C_RESET"
	else
		printf '%s%d upgrade%s available%s — run `%sdotfiles upgrade%s` to apply.\n' \
			"$C_YELLOW" "$upgrade_count" "$([[ $upgrade_count -eq 1 ]] && echo '' || echo 's')" "$C_RESET" \
			"$C_BOLD" "$C_RESET"
	fi
}

print_upgrade_summary() {
	local upgrade_all="${1:-false}"
	local -a rows=()
	local row component installed available _action result
	local ok_count=0 fail_count=0

	mapfile -t rows < <(_collect_check_rows)

	printf '\n%sUpgrade summary%s\n' "$C_BOLD" "$C_RESET"
	printf '%-18s | %-28s | %-22s | %s\n' "component" "installed" "available" "result"
	printf '%s\n' "-------------------+------------------------------+------------------------+----------"

	for row in "${rows[@]}"; do
		IFS='|' read -r component installed available _action <<<"$row"
		result="${UPGRADE_STEP_RESULT[$component]:-}"
		if [[ -z "$result" ]]; then
			case "$component" in
			"Node.js (nvm)" | "Go (asdf)" | "Monaspace fonts")
				if [[ "$upgrade_all" == true ]]; then
					result="skipped"
				else
					result="skipped (--all)"
				fi
				;;
			*) result="—" ;;
			esac
		fi
		case "$result" in
		ok) ((++ok_count)) ;;
		failed) ((++fail_count)) ;;
		esac
		_print_check_table_row "$component" "$installed" "$available" "$result" result
	done

	printf '\n'
	if [[ $fail_count -eq 0 ]]; then
		printf '%sUpgrade finished%s — %d step(s) ok' "$C_GREEN" "$C_RESET" "$ok_count"
		[[ "$upgrade_all" != true ]] && printf ' (opt-in components skipped; use --all)'
		printf '.\n'
	else
		printf '%sUpgrade finished with %d failure(s)%s — see log above.\n' "$C_YELLOW" "$fail_count" "$C_RESET"
	fi
}

print_status_table() {
	local title="${1:-Status summary}"
	local -a rows=()
	local row component installed available action

	mapfile -t rows < <(_collect_check_rows)

	printf '\n%s%s%s\n' "$C_BOLD" "$title" "$C_RESET"
	printf '%-18s | %-28s | %-22s | %s\n' "component" "installed" "available" "status"
	printf '%s\n' "-------------------+------------------------------+------------------------+----------"

	for row in "${rows[@]}"; do
		IFS='|' read -r component installed available action <<<"$row"
		_print_check_table_row "$component" "$installed" "$available" "$action" action
	done
	printf '\n'
}

# --- IDE extensions ---
EXT_ALL_TARGETS=(vscode-wsl cursor-wsl vscode-win cursor-win)
_EXT_ENUM_METHOD=""
_EXT_ENUM_DIR=""

_ext_discover_win_user_dir() {
	local user_dir base
	for user_dir in /mnt/c/Users/*/; do
		[[ -d "$user_dir" ]] || continue
		base="$(basename "$user_dir")"
		case "$base" in
		Public | Default | 'Default User' | 'All Users') continue ;;
		esac
		if [[ -d "${user_dir}.vscode" || -d "${user_dir}.cursor" ]]; then
			printf '%s\n' "${user_dir%/}"
			return 0
		fi
	done
	for user_dir in /mnt/c/Users/*/; do
		[[ -d "$user_dir" ]] || continue
		base="$(basename "$user_dir")"
		case "$base" in
		Public | Default | 'Default User' | 'All Users') continue ;;
		esac
		printf '%s\n' "${user_dir%/}"
		return 0
	done
	return 1
}

_ext_target_platform() {
	case "$1" in
	vscode-wsl | cursor-wsl) printf 'wsl\n' ;;
	vscode-win | cursor-win) printf 'win\n' ;;
	esac
}

_ext_target_label() {
	case "$1" in
	vscode-wsl) printf 'VS Code (WSL)\n' ;;
	cursor-wsl) printf 'Cursor (WSL)\n' ;;
	vscode-win) printf 'VS Code (Windows)\n' ;;
	cursor-win) printf 'Cursor (Windows)\n' ;;
	*) printf '%s\n' "$1" ;;
	esac
}

_ext_get_extensions_dir() {
	local target="$1"
	local win_user
	case "$target" in
	vscode-wsl) printf '%s\n' "${HOME}/.vscode-server/extensions" ;;
	cursor-wsl) printf '%s\n' "${HOME}/.cursor-server/extensions" ;;
	vscode-win)
		win_user="$(_ext_discover_win_user_dir || true)"
		[[ -n "$win_user" ]] && printf '%s\n' "${win_user}/.vscode/extensions"
		;;
	cursor-win)
		win_user="$(_ext_discover_win_user_dir || true)"
		[[ -n "$win_user" ]] && printf '%s\n' "${win_user}/.cursor/extensions"
		;;
	esac
}

_ext_find_wsl_cli() {
	local kind="$1"
	local bin
	case "$kind" in
	code) bin="code" ;;
	cursor) bin="cursor" ;;
	*) return 1 ;;
	esac
	if command -v "$bin" >/dev/null 2>&1; then
		command -v "$bin"
		return 0
	fi
	return 1
}

_ext_find_win_cli() {
	local kind="$1"
	local candidate
	local -a candidates=()
	case "$kind" in
	code)
		candidates=(
			"/mnt/c/Program Files/Microsoft VS Code/bin/code.cmd"
			"/mnt/c/Program Files (x86)/Microsoft VS Code/bin/code.cmd"
		)
		;;
	cursor)
		candidates=(
			"/mnt/c/Program Files/cursor/resources/app/bin/cursor.cmd"
			"/mnt/c/Program Files/Cursor/resources/app/bin/cursor.cmd"
		)
		;;
	*) return 1 ;;
	esac
	for candidate in "${candidates[@]}"; do
		[[ -f "$candidate" ]] && {
			printf '%s\n' "$candidate"
			return 0
		}
	done
	local win_user local_app
	win_user="$(_ext_discover_win_user_dir || true)"
	if [[ -n "$win_user" ]]; then
		case "$kind" in
		code)
			local_app="${win_user}/AppData/Local/Programs/Microsoft VS Code/bin/code.cmd"
			;;
		cursor)
			local_app="${win_user}/AppData/Local/Programs/cursor/resources/app/bin/cursor.cmd"
			local_app_alt="${win_user}/AppData/Local/Programs/Cursor/resources/app/bin/cursor.cmd"
			[[ -f "$local_app_alt" ]] && {
				printf '%s\n' "$local_app_alt"
				return 0
			}
			;;
		esac
		[[ -f "$local_app" ]] && {
			printf '%s\n' "$local_app"
			return 0
		}
	fi
	return 1
}

_ext_find_cli() {
	local target="$1"
	case "$target" in
	vscode-wsl) _ext_find_wsl_cli code ;;
	cursor-wsl) _ext_find_wsl_cli cursor ;;
	vscode-win) _ext_find_win_cli code ;;
	cursor-win) _ext_find_win_cli cursor ;;
	*) return 1 ;;
	esac
}

_ext_win_to_ps_path() {
	local wsl_path="$1"
	if command -v wslpath >/dev/null 2>&1; then
		wslpath -w "$wsl_path"
	else
		# Fallback: /mnt/c/... -> C:\...
		local drive rest
		if [[ "$wsl_path" =~ ^/mnt/([a-zA-Z])/(.*)$ ]]; then
			drive="$(printf '%s' "${BASH_REMATCH[1]}" | tr '[:lower:]' '[:upper:]')"
			rest="${BASH_REMATCH[2]//\//\\}"
			printf '%s:\\%s\n' "$drive" "$rest"
		else
			printf '%s\n' "$wsl_path"
		fi
	fi
}

_ext_run_win_cli() {
	local cli_wsl="$1"
	shift
	local ps_cli arg args=()
	ps_cli="$(_ext_win_to_ps_path "$cli_wsl")"
	ps_cli="${ps_cli//\'/\'\'}"
	for arg in "$@"; do
		args+=("'${arg//\'/\'\'}'")
	done
	powershell.exe -NoProfile -Command "& '${ps_cli}' ${args[*]}"
}

_ext_run_cli() {
	local target="$1"
	local cli="$2"
	shift 2
	case "$(_ext_target_platform "$target")" in
	wsl) "$cli" "$@" ;;
	win) _ext_run_win_cli "$cli" "$@" ;;
	esac
}

_ext_strip_platform_suffix() {
	local name="$1"
	local suffix changed=true
	local -a suffixes=(
		universal linux-x64 linux-arm64 linux-armhf
		win32-x64 win32-arm64 alpine-x64 alpine-arm64 darwin-x64 darwin-arm64
	)
	while [[ "$changed" == true ]]; do
		changed=false
		for suffix in "${suffixes[@]}"; do
			if [[ "$name" == *"-${suffix}" ]]; then
				name="${name%-"${suffix}"}"
				changed=true
			fi
		done
	done
	printf '%s' "$name"
}

_ext_parse_folder() {
	local folder="$1"
	local stripped id ver
	stripped="$(_ext_strip_platform_suffix "$folder")"
	if [[ "$stripped" =~ ^(.+)-([0-9].*)$ ]]; then
		id="${BASH_REMATCH[1]}"
		ver="${BASH_REMATCH[2]}"
		printf '%s@%s\n' "$id" "$ver"
	fi
}

_ext_disk_list() {
	local dir="$1"
	local folder base id_ver id ver
	declare -A best=()
	if [[ ! -d "$dir" ]]; then
		return 0
	fi
	for folder in "$dir"/*/; do
		[[ -d "$folder" ]] || continue
		base="$(basename "$folder")"
		[[ "$base" == .* ]] && continue
		id_ver="$(_ext_parse_folder "$base")"
		[[ -z "$id_ver" ]] && continue
		id="${id_ver%%@*}"
		ver="${id_ver#*@}"
		if [[ -z "${best[$id]:-}" ]] || _version_gt "$ver" "${best[$id]}"; then
			best[$id]="$ver"
		fi
	done
	local key
	for key in "${!best[@]}"; do
		printf '%s@%s\n' "$key" "${best[$key]}"
	done | sort
}

_ext_cli_list() {
	local target="$1"
	local cli="$2"
	local output ext_dir
	output="$(_ext_run_cli "$target" "$cli" --list-extensions --show-versions 2>/dev/null || true)"
	if [[ -n "$output" ]]; then
		printf '%s\n' "$output" | sed '/^[[:space:]]*$/d' | sort -u
		return 0
	fi
	ext_dir="$(_ext_get_extensions_dir "$target")"
	if [[ -n "$ext_dir" && -d "$ext_dir" ]]; then
		output="$(_ext_run_cli "$target" "$cli" --extensions-dir "$ext_dir" --list-extensions --show-versions 2>/dev/null || true)"
		if [[ -n "$output" ]]; then
			printf '%s\n' "$output" | sed '/^[[:space:]]*$/d' | sort -u
			return 0
		fi
	fi
	return 1
}

_ext_list_extensions() {
	local target="$1"
	local cli method dir list
	_EXT_ENUM_DIR="$(_ext_get_extensions_dir "$target")"
	_EXT_ENUM_METHOD="disk"
	method="disk"

	if cli="$(_ext_find_cli "$target" 2>/dev/null || true)" && [[ -n "$cli" ]]; then
		if list="$(_ext_cli_list "$target" "$cli" 2>/dev/null || true)" && [[ -n "$list" ]]; then
			method="cli"
			_EXT_ENUM_METHOD="$method"
			printf '%s\n' "$list"
			return 0
		fi
	fi

	dir="$_EXT_ENUM_DIR"
	if [[ -z "$dir" || ! -d "$dir" ]]; then
		_warn "Extensions dir not found for ${target}: ${dir:-unknown}"
		return 0
	fi
	_EXT_ENUM_METHOD="$method"
	_ext_disk_list "$dir"
}

_ext_obsolete_note() {
	local dir="$1"
	local obsolete_file count
	if [[ ! -d "$dir" ]]; then
		printf 'extensions dir missing\n'
		return
	fi
	obsolete_file="${dir}/.obsolete"
	if [[ -f "$obsolete_file" ]]; then
		count="$(wc -l <"$obsolete_file" | tr -d ' ')"
		printf '%s stale entries in .obsolete\n' "$count"
	else
		printf 'no .obsolete file\n'
	fi
}

_ext_obsolete_count() {
	local dir="$1"
	local obsolete_file
	if [[ ! -d "$dir" ]]; then
		printf '—\n'
		return
	fi
	obsolete_file="${dir}/.obsolete"
	if [[ -f "$obsolete_file" ]]; then
		wc -l <"$obsolete_file" | tr -d ' '
	else
		printf '0\n'
	fi
}

_ext_backup_count() {
	local target="$1"
	local f
	f="$(_ext_backup_file "$target")"
	if [[ ! -f "$f" ]]; then
		printf '0\n'
		return
	fi
	sed '/^[[:space:]]*$/d;/^#/d' "$f" | wc -l | tr -d ' '
}

_ext_norm_ver() {
	local ver="${1:-}"
	[[ -z "$ver" ]] && return
	ver="${ver%-universal}"
	printf '%s' "$ver"
}

_ext_format_delta() {
	local installed="$1"
	local manifest="$2"
	if [[ "$installed" -gt "$manifest" ]]; then
		printf '+%s' "$((installed - manifest))"
	elif [[ "$installed" -lt "$manifest" ]]; then
		printf '-%s' "$((manifest - installed))"
	else
		printf '='
	fi
}

_ext_extra_samples() {
	local -n _items=$1
	local limit="${2:-3}"
	local n="${#_items[@]}"
	local samples="" i id
	if [[ "$n" -eq 0 ]]; then
		return
	fi
	for ((i = 0; i < limit && i < n; i++)); do
		id="${_items[$i]%%@*}"
		if [[ -n "$samples" ]]; then
			samples+=", "
		fi
		samples+="$id"
	done
	if [[ "$n" -gt "$limit" ]]; then
		samples+=" (+$((n - limit)) more)"
	fi
	printf '%s' "$samples"
}

_ext_backup_file() {
	printf '%s/extensions/%s.txt\n' "$DOTFILES_DIR" "$1"
}

_ext_manifest_file() {
	printf '%s/extensions/manifest.json\n' "$DOTFILES_DIR"
}

_ext_write_manifest() {
	local ts="$1"
	shift
	local manifest
	manifest="$(_ext_manifest_file)"
	mkdir -p "$(dirname "$manifest")"
	if ! command -v python3 >/dev/null 2>&1; then
		_warn "python3 not found; skipping manifest.json update"
		return 0
	fi
	MANIFEST_PATH="$manifest" MANIFEST_TS="$ts" MANIFEST_ENTRIES="$*" python3 - <<'PY'
import json, os, sys
from pathlib import Path

manifest_path = Path(os.environ["MANIFEST_PATH"])
ts = os.environ["MANIFEST_TS"]
entries_raw = os.environ.get("MANIFEST_ENTRIES", "")

data = {"updated": ts, "targets": {}}
if manifest_path.is_file():
    try:
        data = json.loads(manifest_path.read_text())
    except json.JSONDecodeError:
        pass
data["updated"] = ts
if "targets" not in data or not isinstance(data["targets"], dict):
    data["targets"] = {}

for chunk in entries_raw.split("|||"):
    if not chunk:
        continue
    parts = chunk.split("|", 3)
    if len(parts) < 4:
        continue
    target, count, method, ext_file = parts
    data["targets"][target] = {
        "count": int(count),
        "method": method,
        "file": ext_file,
    }

manifest_path.parent.mkdir(parents=True, exist_ok=True)
manifest_path.write_text(json.dumps(data, indent=2) + "\n")
PY
}

_ext_resolve_targets() {
	local arg="${1:-all}"
	case "$arg" in
	all) printf '%s\n' "${EXT_ALL_TARGETS[@]}" ;;
	vscode-wsl | cursor-wsl | vscode-win | cursor-win) printf '%s\n' "$arg" ;;
	*)
		_err "Unknown extension target: $arg (expected: vscode-wsl, cursor-wsl, vscode-win, cursor-win, all)"
		return 1
		;;
	esac
}

_ext_read_backup_lines() {
	local file="$1"
	if [[ ! -f "$file" ]]; then
		return 1
	fi
	grep -v '^[[:space:]]*$' "$file" | grep -v '^#' | sort -u
}

_ext_parse_ext_line() {
	local line="$1"
	_EXT_PARSE_ID="${line%%@*}"
	if [[ "$line" == *@* ]]; then
		_EXT_PARSE_VER="${line#*@}"
	else
		_EXT_PARSE_VER=""
	fi
}

_ext_install_extension() {
	local target="$1"
	local ext_line="$2"
	local cli
	cli="$(_ext_find_cli "$target" 2>/dev/null || true)"
	if [[ -z "$cli" ]]; then
		_err "  CLI not found for ${target}; cannot install ${ext_line}"
		return 1
	fi
	_msg "  installing ${ext_line}"
	_ext_run_cli "$target" "$cli" --install-extension "$ext_line" --force
}

_ext_uninstall_extension() {
	local target="$1"
	local ext_id="$2"
	local cli
	cli="$(_ext_find_cli "$target" 2>/dev/null || true)"
	if [[ -z "$cli" ]]; then
		_err "  CLI not found for ${target}; cannot uninstall ${ext_id}"
		return 1
	fi
	_msg "  uninstalling ${ext_id}"
	_ext_run_cli "$target" "$cli" --uninstall-extension "$ext_id"
}

_ext_cmd_check() {
	local target dir method list count manifest stale delta list_file
	printf '\n%sExtensions status%s\n' "$C_BOLD" "$C_RESET"
	printf '%-18s | %9s | %9s | %6s | %6s | %6s\n' "target" "installed" "manifest" "delta" "stale" "method"
	printf '%s\n' "-------------------+-----------+-----------+--------+--------+--------"
	for target in "$@"; do
		dir="$(_ext_get_extensions_dir "$target")"
		list_file="$(mktemp)"
		_ext_list_extensions "$target" >"$list_file"
		list="$(<"$list_file")"
		rm -f "$list_file"
		method="${_EXT_ENUM_METHOD:-disk}"
		count="$(printf '%s\n' "$list" | sed '/^[[:space:]]*$/d' | wc -l | tr -d ' ')"
		manifest="$(_ext_backup_count "$target")"
		stale="$(_ext_obsolete_count "${dir:-}")"
		delta="$(_ext_format_delta "$count" "$manifest")"
		printf '%-18s | %9s | %9s | %6s | ' "$target" "$count" "$manifest"
		# delta: match green; nonzero yellow (informational mismatch)
		if [[ "$delta" == "0" || "$delta" == "+0" || "$delta" == "-0" || "$delta" == "=" ]]; then
			printf '%s%s%s' "$C_GREEN" "$delta" "$C_RESET"
		else
			printf '%s%s%s' "$C_YELLOW" "$delta" "$C_RESET"
		fi
		printf ' | '
		_color_count "$stale" warn 6
		printf ' | %6s\n' "$method"
	done
	printf '\n'
}

_ext_cmd_backup() {
	local target list method dir count outfile manifest_entries="" ts entry list_file
	local ext_dir="${DOTFILES_DIR}/extensions"
	mkdir -p "$ext_dir"
	ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

	for target in "$@"; do
		list_file="$(mktemp)"
		_ext_list_extensions "$target" >"$list_file"
		list="$(<"$list_file")"
		rm -f "$list_file"
		method="${_EXT_ENUM_METHOD:-disk}"
		dir="${_EXT_ENUM_DIR:-$(_ext_get_extensions_dir "$target")}"
		count="$(printf '%s\n' "$list" | sed '/^[[:space:]]*$/d' | wc -l | tr -d ' ')"
		outfile="$(_ext_backup_file "$target")"
		printf '%s\n' "$list" | sed '/^[[:space:]]*$/d' | sort -u >"$outfile"
		_msg "Backed up ${count} extension(s) for ${target} (${method}) -> ${outfile}"
		entry="${target}|${count}|${method}|$(basename "$outfile")"
		if [[ -n "$manifest_entries" ]]; then
			manifest_entries="${manifest_entries}|||${entry}"
		else
			manifest_entries="$entry"
		fi
	done

	_ext_write_manifest "$ts" "$manifest_entries"
	_msg "Updated $(_ext_manifest_file)"
}

_ext_prune_extras() {
	local target="$1"
	local backup_file="$2"
	local cli line
	local -a installed_ids=() backup_ids=()

	cli="$(_ext_find_cli "$target" 2>/dev/null || true)"
	if [[ -z "$cli" ]]; then
		_warn "Cannot prune ${target}: CLI not found"
		return 1
	fi
	while IFS= read -r line; do
		_ext_parse_ext_line "$line"
		[[ -n "$_EXT_PARSE_ID" ]] && installed_ids+=("$_EXT_PARSE_ID")
	done < <(_ext_list_extensions "$target" | sed '/^[[:space:]]*$/d')
	while IFS= read -r line; do
		_ext_parse_ext_line "$line"
		[[ -n "$_EXT_PARSE_ID" ]] && backup_ids+=("$_EXT_PARSE_ID")
	done < <(_ext_read_backup_lines "$backup_file")

	local inst_id found bid
	for inst_id in "${installed_ids[@]}"; do
		found=false
		for bid in "${backup_ids[@]}"; do
			if [[ "$inst_id" == "$bid" ]]; then
				found=true
				break
			fi
		done
		if [[ "$found" == false ]]; then
			_ext_uninstall_extension "$target" "$inst_id" || true
		fi
	done
}

_ext_cmd_restore() {
	local mode="$1"
	shift
	local target backup_file line
	declare -A installed_ver=()

	for target in "$@"; do
		backup_file="$(_ext_backup_file "$target")"
		if [[ ! -f "$backup_file" ]]; then
			if [[ "$mode" == "prune-only" ]]; then
				_warn "No backup file for ${target}: ${backup_file} (nothing to prune against)"
			else
				_err "No backup file for ${target}: ${backup_file}"
			fi
			continue
		fi
		printf '\n%s=== Restoring %s (%s) ===%s\n' "$C_BOLD" "$target" "$mode" "$C_RESET"

		if [[ "$mode" == "all" || "$mode" == "prune" || "$mode" == "missing-only" ]]; then
			installed_ver=()
			if [[ "$mode" == "missing-only" ]]; then
				while IFS= read -r line; do
					_ext_parse_ext_line "$line"
					[[ -n "$_EXT_PARSE_ID" ]] && installed_ver["$_EXT_PARSE_ID"]=1
				done < <(_ext_list_extensions "$target" | sed '/^[[:space:]]*$/d')
			fi
			while IFS= read -r line || [[ -n "$line" ]]; do
				[[ -z "$line" || "$line" =~ ^# ]] && continue
				if [[ "$mode" == "missing-only" ]]; then
					_ext_parse_ext_line "$line"
					if [[ -n "${installed_ver[$_EXT_PARSE_ID]:-}" ]]; then
						continue
					fi
				fi
				_ext_install_extension "$target" "$line" || true
			done <"$backup_file"
		fi

		if [[ "$mode" == "prune" || "$mode" == "prune-only" ]]; then
			_ext_prune_extras "$target" "$backup_file" || true
		fi
	done
}

_ext_collect_missing_rows() {
	local target="$1"
	local backup_file line key
	declare -A backup_ver=() installed_ver=()

	backup_file="$(_ext_backup_file "$target")"
	[[ -f "$backup_file" ]] || return 0

	while IFS= read -r line; do
		_ext_parse_ext_line "$line"
		[[ -n "$_EXT_PARSE_ID" ]] && backup_ver["$_EXT_PARSE_ID"]="$_EXT_PARSE_VER"
	done < <(_ext_read_backup_lines "$backup_file")

	while IFS= read -r line; do
		_ext_parse_ext_line "$line"
		[[ -n "$_EXT_PARSE_ID" ]] && installed_ver["$_EXT_PARSE_ID"]="$_EXT_PARSE_VER"
	done < <(_ext_list_extensions "$target" | sed '/^[[:space:]]*$/d')

	for key in "${!backup_ver[@]}"; do
		if [[ -z "${installed_ver[$key]:-}" ]]; then
			printf '%s|%s|%s\n' "${key}@${backup_ver[$key]}" "$key" "${backup_ver[$key]}"
		fi
	done | sort
}

_ext_collect_extra_rows() {
	local target="$1"
	local backup_file line key
	declare -A backup_ver=() installed_ver=()

	backup_file="$(_ext_backup_file "$target")"
	if [[ -f "$backup_file" ]]; then
		while IFS= read -r line; do
			_ext_parse_ext_line "$line"
			[[ -n "$_EXT_PARSE_ID" ]] && backup_ver["$_EXT_PARSE_ID"]="$_EXT_PARSE_VER"
		done < <(_ext_read_backup_lines "$backup_file")
	fi

	while IFS= read -r line; do
		_ext_parse_ext_line "$line"
		[[ -n "$_EXT_PARSE_ID" ]] && installed_ver["$_EXT_PARSE_ID"]="$_EXT_PARSE_VER"
	done < <(_ext_list_extensions "$target" | sed '/^[[:space:]]*$/d')

	for key in "${!installed_ver[@]}"; do
		if [[ -z "${backup_ver[$key]:-}" ]]; then
			printf '%s|%s|%s\n' "${key}@${installed_ver[$key]}" "$key" "${installed_ver[$key]}"
		fi
	done | sort
}

_ext_collect_edit_rows() {
	local target="$1"
	local backup_file line
	declare -A backup_ids=()

	backup_file="$(_ext_backup_file "$target")"
	if [[ -f "$backup_file" ]]; then
		while IFS= read -r line; do
			_ext_parse_ext_line "$line"
			[[ -n "$_EXT_PARSE_ID" ]] && backup_ids["$_EXT_PARSE_ID"]=1
		done < <(_ext_read_backup_lines "$backup_file")
	fi

	while IFS= read -r line; do
		[[ -z "$line" ]] && continue
		_ext_parse_ext_line "$line"
		if [[ -n "${backup_ids[$_EXT_PARSE_ID]:-}" ]]; then
			printf '1|%s|backed up\n' "$line"
		else
			printf '0|%s|not backed up\n' "$line"
		fi
	done < <(_ext_list_extensions "$target" | sed '/^[[:space:]]*$/d' | sort)
}

# Matrix UI targets (column order matches menu_matrix.sh).
EXT_MATRIX_TARGETS=(vscode-wsl vscode-win cursor-wsl cursor-win)

_ext_compat_file() {
	printf '%s/extensions/ext-compat.tsv\n' "$DOTFILES_DIR"
}

declare -gA _EXT_COMPAT_EXACT=()
declare -ga _EXT_COMPAT_GLOB_PATTERNS=() _EXT_COMPAT_GLOB_FAMILIES=()
declare -g _EXT_COMPAT_LOADED=0

_ext_compat_load() {
	[[ $_EXT_COMPAT_LOADED -eq 1 ]] && return 0
	local f line pattern family
	f="$(_ext_compat_file)"
	_EXT_COMPAT_EXACT=()
	_EXT_COMPAT_GLOB_PATTERNS=()
	_EXT_COMPAT_GLOB_FAMILIES=()
	if [[ -f "$f" ]]; then
		while IFS= read -r line || [[ -n "$line" ]]; do
			[[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && continue
			pattern="${line%%$'\t'*}"
			family="${line#*$'\t'}"
			family="${family%%[[:space:]]*}"
			case "$family" in
			vscode | cursor | both) ;;
			*) continue ;;
			esac
			if [[ "$pattern" == *'*'* || "$pattern" == *'?'* ]]; then
				_EXT_COMPAT_GLOB_PATTERNS+=("$pattern")
				_EXT_COMPAT_GLOB_FAMILIES+=("$family")
			else
				_EXT_COMPAT_EXACT["$pattern"]="$family"
			fi
		done <"$f"
	fi
	_EXT_COMPAT_LOADED=1
}

_ext_target_family() {
	case "$1" in
	vscode-wsl | vscode-win) printf 'vscode\n' ;;
	cursor-wsl | cursor-win) printf 'cursor\n' ;;
	*)
		_err "Unknown extension target: $1"
		return 1
		;;
	esac
}

_ext_compat_extension_family() {
	local ext_id="$1" i pattern
	_ext_compat_load
	if [[ -n "${_EXT_COMPAT_EXACT[$ext_id]:-}" ]]; then
		printf '%s\n' "${_EXT_COMPAT_EXACT[$ext_id]}"
		return 0
	fi
	for i in "${!_EXT_COMPAT_GLOB_PATTERNS[@]}"; do
		pattern="${_EXT_COMPAT_GLOB_PATTERNS[$i]}"
		[[ "$ext_id" == $pattern ]] || continue
		printf '%s\n' "${_EXT_COMPAT_GLOB_FAMILIES[$i]}"
		return 0
	done
	printf 'both\n'
}

_ext_compat_allowed() {
	local ext_id="$1" target="$2" tf ef
	tf="$(_ext_target_family "$target")" || return 1
	ef="$(_ext_compat_extension_family "$ext_id")"
	case "$ef" in
	both) return 0 ;;
	vscode | cursor)
		[[ "$ef" == "$tf" ]]
		;;
	esac
}

_ext_matrix_load_maps() {
	local target="$1"
	local -n _out_manifest="$2"
	local -n _out_installed="$3"
	local backup_file line

	_out_manifest=()
	_out_installed=()
	backup_file="$(_ext_backup_file "$target")"
	if [[ -f "$backup_file" ]]; then
		while IFS= read -r line; do
			_ext_parse_ext_line "$line"
			[[ -n "$_EXT_PARSE_ID" ]] && _out_manifest["$_EXT_PARSE_ID"]="$_EXT_PARSE_VER"
		done < <(_ext_read_backup_lines "$backup_file")
	fi

	while IFS= read -r line; do
		_ext_parse_ext_line "$line"
		[[ -n "$_EXT_PARSE_ID" ]] && _out_installed["$_EXT_PARSE_ID"]="$_EXT_PARSE_VER"
	done < <(_ext_list_extensions "$target" | sed '/^[[:space:]]*$/d')
}

_ext_matrix_line_for() {
	local ext_id="$1"
	local ver="$2"
	if [[ -n "$ver" ]]; then
		printf '%s@%s\n' "$ext_id" "$ver"
	else
		printf '%s\n' "$ext_id"
	fi
}

_ext_matrix_union_keys() {
	local mode="$1"
	declare -A union=() filtered=()
	local ext_id

	for ext_id in "${!_MX_m0[@]}" "${!_MX_i0[@]}" \
		"${!_MX_m1[@]}" "${!_MX_i1[@]}" \
		"${!_MX_m2[@]}" "${!_MX_i2[@]}" \
		"${!_MX_m3[@]}" "${!_MX_i3[@]}"; do
		union["$ext_id"]=1
	done

	case "$mode" in
	edit)
		printf '%s\n' "${!union[@]}"
		return 0
		;;
	missing)
		for ext_id in "${!union[@]}"; do
			if { [[ -n "${_MX_m0[$ext_id]:-}" ]] && [[ -z "${_MX_i0[$ext_id]:-}" ]]; } \
				|| { [[ -n "${_MX_m1[$ext_id]:-}" ]] && [[ -z "${_MX_i1[$ext_id]:-}" ]]; } \
				|| { [[ -n "${_MX_m2[$ext_id]:-}" ]] && [[ -z "${_MX_i2[$ext_id]:-}" ]]; } \
				|| { [[ -n "${_MX_m3[$ext_id]:-}" ]] && [[ -z "${_MX_i3[$ext_id]:-}" ]]; }; then
				filtered["$ext_id"]=1
			fi
		done
		printf '%s\n' "${!filtered[@]}"
		;;
	extra)
		for ext_id in "${!union[@]}"; do
			if { [[ -n "${_MX_i0[$ext_id]:-}" ]] && [[ -z "${_MX_m0[$ext_id]:-}" ]]; } \
				|| { [[ -n "${_MX_i1[$ext_id]:-}" ]] && [[ -z "${_MX_m1[$ext_id]:-}" ]]; } \
				|| { [[ -n "${_MX_i2[$ext_id]:-}" ]] && [[ -z "${_MX_m2[$ext_id]:-}" ]]; } \
				|| { [[ -n "${_MX_i3[$ext_id]:-}" ]] && [[ -z "${_MX_m3[$ext_id]:-}" ]]; }; then
				filtered["$ext_id"]=1
			fi
		done
		printf '%s\n' "${!filtered[@]}"
		;;
	esac
}

_ext_matrix_cell_fields() {
	local ext_id="$1"
	local -n _mf="$2"
	local -n _inf="$3"
	local -n _line_out="$4"
	local -n _m_out="$5"
	local -n _i_out="$6"

	_line_out=""
	_m_out=0
	_i_out=0
	[[ -n "${_mf[$ext_id]:-}" ]] && _m_out=1
	[[ -n "${_inf[$ext_id]:-}" ]] && _i_out=1
	if [[ "$_i_out" -eq 1 ]]; then
		_line_out="$(_ext_matrix_line_for "$ext_id" "${_inf[$ext_id]}")"
	elif [[ "$_m_out" -eq 1 ]]; then
		_line_out="$(_ext_matrix_line_for "$ext_id" "${_mf[$ext_id]}")"
	fi
}

_ext_matrix_emit_rows() {
	local mode="$1"
	local -a ids=() row_parts=()
	local ext_id display line m_flag i_flag

	declare -gA _MX_m0=() _MX_i0=()
	declare -gA _MX_m1=() _MX_i1=()
	declare -gA _MX_m2=() _MX_i2=()
	declare -gA _MX_m3=() _MX_i3=()

	_ext_matrix_load_maps "${EXT_MATRIX_TARGETS[0]}" _MX_m0 _MX_i0
	_ext_matrix_load_maps "${EXT_MATRIX_TARGETS[1]}" _MX_m1 _MX_i1
	_ext_matrix_load_maps "${EXT_MATRIX_TARGETS[2]}" _MX_m2 _MX_i2
	_ext_matrix_load_maps "${EXT_MATRIX_TARGETS[3]}" _MX_m3 _MX_i3

	mapfile -t ids < <(_ext_matrix_union_keys "$mode" | sort)
	((${#ids[@]} == 0)) && return 0

	for ext_id in "${ids[@]}"; do
		display=""
		row_parts=("$ext_id" "")
		_ext_matrix_cell_fields "$ext_id" _MX_m0 _MX_i0 line m_flag i_flag
		[[ -z "$display" && -n "$line" ]] && display="$line"
		row_parts+=("$line" "$m_flag" "$i_flag")
		_ext_matrix_cell_fields "$ext_id" _MX_m1 _MX_i1 line m_flag i_flag
		[[ -z "$display" && -n "$line" ]] && display="$line"
		row_parts+=("$line" "$m_flag" "$i_flag")
		_ext_matrix_cell_fields "$ext_id" _MX_m2 _MX_i2 line m_flag i_flag
		[[ -z "$display" && -n "$line" ]] && display="$line"
		row_parts+=("$line" "$m_flag" "$i_flag")
		_ext_matrix_cell_fields "$ext_id" _MX_m3 _MX_i3 line m_flag i_flag
		[[ -z "$display" && -n "$line" ]] && display="$line"
		row_parts+=("$line" "$m_flag" "$i_flag")
		[[ -z "$display" ]] && display="$ext_id"
		row_parts[1]="$display"
		for c in 0 1 2 3; do
			if _ext_compat_allowed "$ext_id" "${EXT_MATRIX_TARGETS[$c]}"; then
				row_parts+=("1")
			else
				row_parts+=("0")
			fi
		done
		local IFS='|'
		printf '%s\n' "${row_parts[*]}"
	done
}

_ext_collect_edit_rows_all() {
	_ext_matrix_emit_rows edit
}

_ext_collect_missing_rows_all() {
	_ext_matrix_emit_rows missing
}

_ext_collect_extra_rows_all() {
	_ext_matrix_emit_rows extra
}

_ext_cmd_sync_manifest() {
	local target="$1"
	local outfile ts count entry kept removed=0 line key
	local -a new_lines=()
	declare -A old_ids=() new_ids=()

	outfile="$(_ext_backup_file "$target")"
	mkdir -p "$(dirname "$outfile")"

	if [[ -f "$outfile" ]]; then
		while IFS= read -r line; do
			_ext_parse_ext_line "$line"
			[[ -n "$_EXT_PARSE_ID" ]] && old_ids["$_EXT_PARSE_ID"]=1
		done < <(_ext_read_backup_lines "$outfile")
	fi

	while IFS= read -r line; do
		[[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && continue
		new_lines+=("$line")
		_ext_parse_ext_line "$line"
		[[ -n "$_EXT_PARSE_ID" ]] && new_ids["$_EXT_PARSE_ID"]=1
	done

	for key in "${!old_ids[@]}"; do
		if [[ -z "${new_ids[$key]:-}" ]]; then
			removed=$((removed + 1))
		fi
	done

	if [[ ${#new_lines[@]} -gt 0 ]]; then
		printf '%s\n' "${new_lines[@]}" | sort -u >"$outfile"
		kept="$(wc -l <"$outfile" | tr -d ' ')"
	else
		: >"$outfile"
		kept=0
	fi

	ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
	count="$kept"
	entry="${target}|${count}|manifest-sync|$(basename "$outfile")"
	_ext_write_manifest "$ts" "$entry"
	_msg "kept ${kept}, removed ${removed} from manifest"
}

_ext_cmd_install_lines() {
	local target="$1"
	local line

	while IFS= read -r line; do
		[[ -z "$line" || "$line" =~ ^# ]] && continue
		_ext_install_extension "$target" "$line" || true
	done
}

_ext_cmd_remove_lines() {
	local target="$1"
	local line

	while IFS= read -r line; do
		[[ -z "$line" ]] && continue
		_ext_parse_ext_line "$line"
		[[ -n "$_EXT_PARSE_ID" ]] && _ext_uninstall_extension "$target" "$_EXT_PARSE_ID" || true
	done
}

_ext_cmd_compare() {
	local verbose="${1:-false}"
	shift
	local target backup_file line key
	declare -A backup_ver installed_ver
	local -a only_backup=() only_installed=() drift=()
	local -a summary_targets=() summary_manifest=() summary_installed=()
	local -a summary_missing=() summary_extra=() summary_drift=()
	local -a missing_rows=() drift_rows=() extra_rows=()
	local backup_n installed_n has_diff=false samples

	for target in "$@"; do
		backup_file="$(_ext_backup_file "$target")"
		backup_ver=()
		installed_ver=()
		only_backup=()
		only_installed=()
		drift=()

		if [[ ! -f "$backup_file" ]]; then
			_warn "No backup file: ${backup_file}"
			continue
		fi

		while IFS= read -r line; do
			_ext_parse_ext_line "$line"
			[[ -n "$_EXT_PARSE_ID" ]] && backup_ver["$_EXT_PARSE_ID"]="$_EXT_PARSE_VER"
		done < <(_ext_read_backup_lines "$backup_file")

		while IFS= read -r line; do
			_ext_parse_ext_line "$line"
			[[ -n "$_EXT_PARSE_ID" ]] && installed_ver["$_EXT_PARSE_ID"]="$_EXT_PARSE_VER"
		done < <(_ext_list_extensions "$target" | sed '/^[[:space:]]*$/d')

		for key in "${!backup_ver[@]}"; do
			if [[ -z "${installed_ver[$key]:-}" ]]; then
				only_backup+=("${key}@${backup_ver[$key]}")
				missing_rows+=("${target}|${key}|${backup_ver[$key]}")
			elif [[ "$(_ext_norm_ver "${backup_ver[$key]}")" != "$(_ext_norm_ver "${installed_ver[$key]}")" ]]; then
				drift+=("${key}")
				drift_rows+=("${target}|${key}|${backup_ver[$key]}|${installed_ver[$key]}")
			fi
		done
		for key in "${!installed_ver[@]}"; do
			if [[ -z "${backup_ver[$key]:-}" ]]; then
				only_installed+=("${key}@${installed_ver[$key]}")
			fi
		done

		if [[ ${#only_backup[@]} -gt 0 ]]; then
			mapfile -t only_backup < <(printf '%s\n' "${only_backup[@]}" | sort)
		fi
		if [[ ${#only_installed[@]} -gt 0 ]]; then
			mapfile -t only_installed < <(printf '%s\n' "${only_installed[@]}" | sort)
		fi
		if [[ ${#drift[@]} -gt 0 ]]; then
			mapfile -t drift < <(printf '%s\n' "${drift[@]}" | sort)
		fi

		backup_n="${#backup_ver[@]}"
		installed_n="${#installed_ver[@]}"
		summary_targets+=("$target")
		summary_manifest+=("$backup_n")
		summary_installed+=("$installed_n")
		summary_missing+=("${#only_backup[@]}")
		summary_extra+=("${#only_installed[@]}")
		summary_drift+=("${#drift[@]}")
		if [[ ${#only_backup[@]} -gt 0 || ${#only_installed[@]} -gt 0 || ${#drift[@]} -gt 0 ]]; then
			has_diff=true
		fi
		if [[ ${#only_installed[@]} -gt 0 ]]; then
			samples="$(_ext_extra_samples only_installed)"
			extra_rows+=("${target}|${#only_installed[@]}|${samples}")
		fi
	done

	if [[ ${#summary_targets[@]} -eq 0 ]]; then
		printf '\n'
		return
	fi

	if _dotfiles_tui_mode && declare -F rt_print_table_row >/dev/null 2>&1; then
		local i row ext_id manifest_ver installed_ver_col count examples detail result
		local ok_count=0 check_count=0 miss_count=0

		rt_print_table_columns
		for i in "${!summary_targets[@]}"; do
			detail="manifest ${summary_manifest[$i]} · installed ${summary_installed[$i]} · missing ${summary_missing[$i]} · extra ${summary_extra[$i]} · drift ${summary_drift[$i]}"
			if [[ "${summary_missing[$i]}" -eq 0 && "${summary_extra[$i]}" -eq 0 && "${summary_drift[$i]}" -eq 0 ]]; then
				result=ok
				((++ok_count))
			else
				result=check
				((++check_count))
			fi
			rt_print_table_row "${summary_targets[$i]}" "$detail" "$result"
		done

		if [[ "$has_diff" != true ]]; then
			rt_print_rollup "$ok_count" 0 0
			return
		fi

		if [[ ${#missing_rows[@]} -gt 0 ]]; then
			mapfile -t missing_rows < <(printf '%s\n' "${missing_rows[@]}" | sort)
			rt_print_section "── Missing (manifest, not installed) ──"
			for row in "${missing_rows[@]}"; do
				IFS='|' read -r target ext_id manifest_ver <<<"$row"
				rt_print_table_row "$target" "${ext_id}@${manifest_ver:-latest}" missing
				((++miss_count))
			done
		fi

		if [[ ${#drift_rows[@]} -gt 0 ]]; then
			mapfile -t drift_rows < <(printf '%s\n' "${drift_rows[@]}" | sort)
			rt_print_section "── Version drift ──"
			for row in "${drift_rows[@]}"; do
				IFS='|' read -r target ext_id manifest_ver installed_ver_col <<<"$row"
				rt_print_table_row "$target" \
					"${ext_id} manifest ${manifest_ver} · installed ${installed_ver_col}" drift
				((++check_count))
			done
		fi

		if [[ ${#extra_rows[@]} -gt 0 ]]; then
			rt_print_section "── Extra installed (not in manifest) ──"
			for row in "${extra_rows[@]}"; do
				IFS='|' read -r target count examples <<<"$row"
				rt_print_table_row "$target" "${count} extra · ${examples:0:40}" extra
				((++check_count))
			done
			printf '  %sRestore with prune: dotfiles ext restore <target> --prune%s\n' "$C_DIM" "$C_RESET"
		fi

		rt_print_rollup "$ok_count" "$check_count" "$miss_count"
		return
	fi

	printf '\n%sCompare summary (manifest vs installed)%s\n' "$C_BOLD" "$C_RESET"
	printf '%-18s | %7s | %9s | %7s | %5s | %5s\n' "target" "manifest" "installed" "missing" "extra" "drift"
	printf '%s\n' "-------------------+---------+-----------+---------+-------+-------"
	local i
	for i in "${!summary_targets[@]}"; do
		printf '%-18s | %7s | %9s | ' \
			"${summary_targets[$i]}" \
			"${summary_manifest[$i]}" \
			"${summary_installed[$i]}"
		_color_count "${summary_missing[$i]}" err 7
		printf ' | '
		_color_count "${summary_extra[$i]}" warn 5
		printf ' | '
		_color_count "${summary_drift[$i]}" warn 5
		printf '\n'
	done

	if [[ "$has_diff" != true ]]; then
		printf '\n%sAll targets match their manifests.%s\n\n' "$C_GREEN" "$C_RESET"
		return
	fi

	if [[ ${#missing_rows[@]} -gt 0 ]]; then
		mapfile -t missing_rows < <(printf '%s\n' "${missing_rows[@]}" | sort)
		printf '\n%sMissing (in manifest, not installed)%s\n' "$C_BOLD" "$C_RESET"
		printf '%-18s | %-40s | %-20s | %s\n' "target" "extension" "manifest" "result"
		printf '%s\n' "-------------------+------------------------------------------+----------------------+----------"
		local row ext_id manifest_ver
		for row in "${missing_rows[@]}"; do
			IFS='|' read -r target ext_id manifest_ver <<<"$row"
			printf '%-18s | %-40s | %-20s | ' "$target" "$ext_id" "${manifest_ver:-—}"
			_color_result "missing"
			printf '\n'
		done
	fi

	if [[ ${#drift_rows[@]} -gt 0 ]]; then
		mapfile -t drift_rows < <(printf '%s\n' "${drift_rows[@]}" | sort)
		printf '\n%sVersion drift%s\n' "$C_BOLD" "$C_RESET"
		printf '%-18s | %-40s | %-20s | %-20s | %s\n' "target" "extension" "manifest" "installed" "result"
		printf '%s\n' "-------------------+------------------------------------------+----------------------+----------------------+----------"
		local row ext_id manifest_ver installed_ver_col
		for row in "${drift_rows[@]}"; do
			IFS='|' read -r target ext_id manifest_ver installed_ver_col <<<"$row"
			printf '%-18s | %-40s | %-20s | %-20s | ' \
				"$target" "$ext_id" "$manifest_ver" "$installed_ver_col"
			_color_result "drift"
			printf '\n'
		done
	fi

	if [[ ${#extra_rows[@]} -gt 0 ]]; then
		printf '\n%sExtra installed (not in manifest)%s\n' "$C_BOLD" "$C_RESET"
		printf '%-18s | %5s | %-40s | %s\n' "target" "count" "examples" "result"
		printf '%s\n' "-------------------+-------+------------------------------------------+----------"
		local count examples
		for row in "${extra_rows[@]}"; do
			IFS='|' read -r target count examples <<<"$row"
			printf '%-18s | ' "$target"
			_color_count "$count" warn 5
			printf ' | %-40s | ' "${examples:0:40}"
			_color_result "extra"
			printf '\n'
		done
		printf '\n  prune extras: dotfiles ext restore <target> --prune\n'
	fi

	if [[ "$verbose" == true && ${#extra_rows[@]} -gt 0 ]]; then
		printf '\n%sExtra installed (full list)%s\n' "$C_BOLD" "$C_RESET"
		printf '%-18s | %-40s | %s\n' "target" "extension" "installed"
		printf '%s\n' "-------------------+------------------------------------------+----------------------"
		for target in "$@"; do
			backup_file="$(_ext_backup_file "$target")"
			[[ -f "$backup_file" ]] || continue
			backup_ver=()
			installed_ver=()
			while IFS= read -r line; do
				_ext_parse_ext_line "$line"
				[[ -n "$_EXT_PARSE_ID" ]] && backup_ver["$_EXT_PARSE_ID"]="$_EXT_PARSE_VER"
			done < <(_ext_read_backup_lines "$backup_file")
			while IFS= read -r line; do
				_ext_parse_ext_line "$line"
				[[ -n "$_EXT_PARSE_ID" ]] && installed_ver["$_EXT_PARSE_ID"]="$_EXT_PARSE_VER"
			done < <(_ext_list_extensions "$target" | sed '/^[[:space:]]*$/d')
			for key in "${!installed_ver[@]}"; do
				if [[ -z "${backup_ver[$key]:-}" ]]; then
					printf '%-18s | %-40s | %s\n' "$target" "$key" "${installed_ver[$key]}"
				fi
			done
		done
	fi
	printf '\n'
}

cmd_ext_help() {
	cat <<EOF
Usage: dotfiles ext <subcommand> [target] [options]

Subcommands:
  check [target]           Table of installed vs manifest counts per target
  backup [target]          Write manifests to extensions/<target>.txt + manifest.json
  restore [target]         Install extensions from manifest
                           --missing-only  install only manifest entries not installed
                           --prune-only    uninstall extras only (no install pass)
                           --prune         install all then uninstall extras
                           --yes           skip prune confirmation (required if non-TTY)
  compare [target]         Table diff: manifest vs installed (missing, extra, drift)
                           Use --verbose to list every extra extension
  sync-manifest <target>   Write extension lines from stdin to manifest (manifest-sync)
  list-edit <target>       TSV: checked|line|status for installed extensions
  list-edit-all            Matrix TSV: all targets (vscode-wsl, vscode-win, cursor-wsl, cursor-win)
  list-missing <target>    TSV: line|id|version for manifest entries not installed
  list-missing-all         Matrix TSV: missing cells across all targets
  list-extra <target>      TSV: line|id|version for installed extras not in manifest
  list-extra-all           Matrix TSV: extra cells across all targets
  install-lines <target>   Install extension lines read from stdin
  remove-lines <target>    Uninstall extensions (lines or ids) read from stdin

Targets: vscode-wsl, cursor-wsl, vscode-win, cursor-win, all (default: all)
         list-* and sync-manifest require a single target (not all)

Examples:
  dotfiles ext check
  dotfiles ext backup cursor-wsl
  dotfiles ext restore all
  dotfiles ext restore cursor-wsl --prune
  dotfiles ext restore cursor-wsl --missing-only
  dotfiles ext restore cursor-wsl --prune-only
  dotfiles ext compare vscode-win
  dotfiles ext list-edit cursor-wsl
  printf '%s\n' 'publisher.ext@1.0' | dotfiles ext sync-manifest cursor-wsl
EOF
}

cmd_ext() {
	local subcmd="${1:-}"
	[[ -z "$subcmd" ]] && {
		cmd_ext_help
		return 1
	}
	shift

	local target="all"
	local restore_mode="all"
	local restore_yes=false
	local compare_verbose=false

	case "$subcmd" in
	list-edit-all)
		_ext_collect_edit_rows_all
		return 0
		;;
	list-missing-all)
		_ext_collect_missing_rows_all
		return 0
		;;
	list-extra-all)
		_ext_collect_extra_rows_all
		return 0
		;;
	sync-manifest | list-edit | list-missing | list-extra | install-lines | remove-lines)
		if [[ $# -lt 1 || "$1" == -* ]]; then
			_err "${subcmd} requires a target (vscode-wsl, cursor-wsl, vscode-win, cursor-win)"
			cmd_ext_help
			return 1
		fi
		target="$1"
		shift
		if [[ $# -gt 0 ]]; then
			_err "Unexpected argument: $1"
			cmd_ext_help
			return 1
		fi
		case "$target" in
		vscode-wsl | cursor-wsl | vscode-win | cursor-win) ;;
		*)
			_err "Unknown extension target: $target"
			cmd_ext_help
			return 1
			;;
		esac
		case "$subcmd" in
		sync-manifest) _ext_cmd_sync_manifest "$target" ;;
		list-edit) _ext_collect_edit_rows "$target" ;;
		list-missing) _ext_collect_missing_rows "$target" ;;
		list-extra) _ext_collect_extra_rows "$target" ;;
		install-lines) _ext_cmd_install_lines "$target" ;;
		remove-lines) _ext_cmd_remove_lines "$target" ;;
		esac
		return 0
		;;
	esac

	case "$subcmd" in
	check | backup)
		if [[ $# -gt 0 && "$1" != -* ]]; then
			target="$1"
			shift
		fi
		;;
	compare)
		if [[ $# -gt 0 && "$1" != -* ]]; then
			target="$1"
			shift
		fi
		while [[ $# -gt 0 ]]; do
			case "$1" in
			--verbose) compare_verbose=true ;;
			-h | --help)
				cmd_ext_help
				return 0
				;;
			-*)
				_err "Unknown option: $1"
				cmd_ext_help
				return 1
				;;
			*)
				_err "Unexpected argument: $1"
				cmd_ext_help
				return 1
				;;
			esac
			shift
		done
		;;
	restore)
		while [[ $# -gt 0 ]]; do
			case "$1" in
			--prune) restore_mode="prune" ;;
			--missing-only) restore_mode="missing-only" ;;
			--prune-only) restore_mode="prune-only" ;;
			--yes) restore_yes=true ;;
			-h | --help)
				cmd_ext_help
				return 0
				;;
			-*)
				_err "Unknown option: $1"
				cmd_ext_help
				return 1
				;;
			*)
				if [[ "$target" == "all" ]]; then
					target="$1"
				else
					_err "Unexpected argument: $1"
					cmd_ext_help
					return 1
				fi
				;;
			esac
			shift
		done
		;;
	help | -h | --help)
		cmd_ext_help
		return 0
		;;
	*)
		_err "Unknown ext subcommand: $subcmd"
		cmd_ext_help
		return 1
		;;
	esac

	if [[ $# -gt 0 ]]; then
		_err "Unexpected argument: $1"
		cmd_ext_help
		return 1
	fi

	local -a targets=()
	local t
	while IFS= read -r t; do
		[[ -n "$t" ]] && targets+=("$t")
	done < <(_ext_resolve_targets "$target" || return 1)

	case "$subcmd" in
	check) _ext_cmd_check "${targets[@]}" ;;
	backup) _ext_cmd_backup "${targets[@]}" ;;
	restore)
		if [[ "$restore_mode" == "prune" || "$restore_mode" == "prune-only" ]]; then
			if [[ ! -t 0 ]]; then
				if [[ "$restore_yes" != true ]]; then
					_err "Prune requires --yes in non-interactive mode"
					return 1
				fi
			elif [[ "$restore_yes" != true ]]; then
				printf '%sWarning: %s will uninstall extensions not in the manifest.%s\n' \
					"$C_YELLOW" "$restore_mode" "$C_RESET"
				printf 'Continue? [y/N] '
				local confirm
				read -r confirm
				case "$confirm" in
				[yY] | [yY][eE][sS]) ;;
				*)
					_msg "Aborted."
					return 1
					;;
				esac
			fi
		fi
		_ext_cmd_restore "$restore_mode" "${targets[@]}"
		;;
	compare) _ext_cmd_compare "$compare_verbose" "${targets[@]}" ;;
	esac
}

# --- Subcommands ---
cmd_update() {
	print_report_table
	exit 0
}

cmd_upgrade() {
	local upgrade_all=false
	local arg

	UPGRADE_STEP_RESULT=()

	for arg in "$@"; do
		case "$arg" in
		--all) upgrade_all=true ;;
		-h | --help)
			cmd_help
			return 0
			;;
		*)
			_err "Unknown option: $arg"
			_msg "Usage: dotfiles upgrade [--all]"
			return 1
			;;
		esac
	done

	_run_upgrade_step "apt packages" upgrade_apt
	_run_upgrade_step "Cursor CLI" upgrade_cursor_cli
	_run_upgrade_step "Codex CLI" upgrade_codex_cli
	_run_upgrade_step "Claude CLI" upgrade_claude_cli
	_run_upgrade_step "Copilot CLI" upgrade_copilot_cli
	_run_upgrade_step "lazygit" upgrade_lazygit
	_run_upgrade_step "lazydocker" upgrade_lazydocker

	if [[ "$upgrade_all" == true ]]; then
		_run_upgrade_step "Node.js (nvm)" upgrade_node
		_run_upgrade_step "Go (asdf)" upgrade_go
		_run_upgrade_step "Monaspace fonts" upgrade_monaspace
	else
		_msg ""
		_msg "${C_DIM}Skipping opt-in upgrades (Node.js, Go, Monaspace). Use --all to include them.${C_RESET}"
	fi

	print_upgrade_summary "$upgrade_all"
}

cmd_summary() {
	print_status_table "Status summary"
}

cmd_status() {
	printf '%s=== Installed versions ===%s\n\n' "$C_BOLD" "$C_RESET"

	printf '  %-20s %s\n' "apt:" "$(command -v apt-get >/dev/null 2>&1 && echo "available" || echo "$NOT_INSTALLED")"
	printf '  %-20s %s\n' "Cursor CLI:" "$(cursor_installed_version)"
	printf '  %-20s %s\n' "Codex CLI:" "$(codex_installed_version)"
	printf '  %-20s %s\n' "Claude CLI:" "$(claude_installed_version)"
	printf '  %-20s %s\n' "Copilot CLI:" "$(copilot_installed_version)"
	printf '  %-20s %s\n' "lazygit:" "$(lazygit_installed_version)"
	printf '  %-20s %s\n' "lazydocker:" "$(lazydocker_installed_version)"
	printf '  %-20s %s\n' "Node.js:" "$(node_installed_version)"
	printf '  %-20s %s\n' "Go:" "$(go_installed_version)"
	printf '  %-20s %s\n' "Monaspace:" "$(monaspace_installed_version)"

	printf '\n%s=== Dotfiles repo ===%s\n' "$C_BOLD" "$C_RESET"
	if command -v git >/dev/null 2>&1; then
		git -C "$DOTFILES_DIR" status -sb
	else
		_msg "git $NOT_INSTALLED"
	fi
}

cmd_restow() {
	if ! command -v stow >/dev/null 2>&1; then
		_err "Error: 'stow' is not installed."
		exit 1
	fi
	stow --dir "$DOTFILES_DIR" --target "$HOME" --restow bash bin readline
	_msg "Dotfiles restowed."
}

cmd_self() {
	if ! command -v git >/dev/null 2>&1; then
		_err "Error: git is not installed."
		exit 1
	fi
	git -C "$DOTFILES_DIR" pull
	cmd_restow
}

cmd_menu() {
	local installer="${DOTFILES_DIR}/install.sh"
	if [[ ! -f "$installer" ]]; then
		_err "Error: install.sh not found at ${installer}"
		exit 1
	fi
	exec bash "$installer" "$@"
}

cmd_help() {
	cat <<EOF
Usage: dotfiles <command> [options]

Commands:
  menu       Boot menu (initial setup / update / extensions / agents)
  summary    Post-run status table (installed versions)
  update     Dry-run report of upgradable components (no changes)
  upgrade    Apply upgrades (apt, CLIs, GitHub tools)
             Use --all to include Node.js, Go, and Monaspace fonts
  status     Show installed versions and dotfiles git status
  restow     Re-apply stow for bash, bin, readline
  self       git pull dotfiles repo, then restow
  ext        IDE extension backup/restore (see: dotfiles ext help)
  help       Show this help

Examples:
  dotfiles menu
  dotfiles summary
  dotfiles update
  dotfiles upgrade
  dotfiles upgrade --all
  dotfiles status
  dotfiles self

Repo: ${DOTFILES_DIR}
EOF
}

main() {
	case "${1:-}" in
	menu) shift; cmd_menu "$@" ;;
	summary) cmd_summary ;;
	update) cmd_update ;;
	upgrade) shift; cmd_upgrade "$@" ;;
	status) cmd_status ;;
	restow) cmd_restow ;;
	self) cmd_self ;;
	ext) shift; cmd_ext "$@" ;;
	help | -h | --help) cmd_help ;;
	'')
		if [[ -t 1 ]]; then
			cmd_menu
		else
			cmd_help
		fi
		;;
	*)
		_err "Unknown command: $1"
		_msg ""
		cmd_help
		exit 1
		;;
	esac
}

main "$@"
