#!/usr/bin/env bash
set -euo pipefail

_script="$(readlink -f "${BASH_SOURCE[0]}")"
DOTFILES_DIR="$(dirname "$(dirname "$(dirname "$_script")")")"

# --- TTY colors ---
if [[ -t 1 ]]; then
	C_RESET=$'\033[0m'
	C_BOLD=$'\033[1m'
	C_DIM=$'\033[2m'
	C_GREEN=$'\033[32m'
	C_YELLOW=$'\033[33m'
	C_CYAN=$'\033[36m'
	C_RED=$'\033[31m'
else
	C_RESET=''
	C_BOLD=''
	C_DIM=''
	C_GREEN=''
	C_YELLOW=''
	C_CYAN=''
	C_RED=''
fi

NOT_INSTALLED='not installed'

# --- Helpers ---
_msg() { printf '%s\n' "$*"; }
_warn() { printf '%s%s%s\n' "$C_YELLOW" "$*" "$C_RESET" >&2; }
_err() { printf '%s%s%s\n' "$C_RED" "$*" "$C_RESET" >&2; }

declare -A UPGRADE_STEP_RESULT=()

_run_upgrade_step() {
	local label="$1"
	shift
	printf '\n%s=== %s ===%s\n' "$C_BOLD" "$label" "$C_RESET"
	set +e
	"$@"
	local rc=$?
	set -e
	if [[ $rc -ne 0 ]]; then
		_warn "  ${label} failed (exit ${rc})"
		UPGRADE_STEP_RESULT["$label"]="failed"
	else
		UPGRADE_STEP_RESULT["$label"]="ok"
	fi
}

_github_latest_version() {
	local repo="$1"
	command -v curl >/dev/null 2>&1 || return 1
	curl -fsSL "https://api.github.com/repos/${repo}/releases/latest" 2>/dev/null |
		grep -Po '"tag_name":\s*"v\K[^"]*' | head -n1
}

_version_gt() {
	# Returns 0 if $1 > $2 (sort -V)
	[[ "$(printf '%s\n%s\n' "$2" "$1" | sort -V | tail -n1)" == "$1" && "$1" != "$2" ]]
}

# Verify tarball SHA256 appears in a GitHub release checksums.txt (filename-agnostic).
_verify_github_tarball_checksum() {
	local dir="$1" tarball="$2" checksums_file="$3"
	local actual

	[[ -f "$dir/$tarball" && -f "$dir/$checksums_file" ]] || return 1
	actual="$(sha256sum "$dir/$tarball" | awk '{print $1}')"
	grep -qF "$actual" "$dir/$checksums_file"
}

_load_nvm() {
	local nvm_dir="${NVM_DIR:-$HOME/.nvm}"
	# shellcheck source=/dev/null
	[[ -s "${nvm_dir}/nvm.sh" ]] && . "${nvm_dir}/nvm.sh"
}

# --- apt ---
apt_upgradable_count() {
	if ! command -v apt-get >/dev/null 2>&1; then
		echo 0
		return
	fi
	local count
	count="$(apt-get -s upgrade 2>/dev/null | grep -c '^Inst' || true)"
	echo "${count:-0}"
}

check_apt() {
	local count installed available action upgradable=0
	count="$(apt_upgradable_count)"
	if command -v apt-get >/dev/null 2>&1; then
		installed="system packages"
	else
		installed="$NOT_INSTALLED"
	fi
	if [[ "$count" -gt 0 ]]; then
		available="${count} package(s)"
		action="upgrade"
		upgradable=1
	else
		available="none"
		action="up to date"
	fi
	printf '%s|%s|%s|%s\n' "apt packages" "$installed" "$available" "$action"
	[[ $upgradable -eq 1 ]]
}

upgrade_apt() {
	if ! command -v apt-get >/dev/null 2>&1; then
		_warn "apt-get not found, skipping apt upgrade"
		return 0
	fi
	sudo apt-get update -qq && sudo apt-get -o Dpkg::Use-Pty=0 upgrade -y
}

# --- Cursor CLI ---
cursor_installed_version() {
	if command -v agent >/dev/null 2>&1; then
		agent --version 2>/dev/null | head -n1 || echo "installed"
	elif command -v cursor >/dev/null 2>&1; then
		cursor --version 2>/dev/null | head -n1 || echo "installed"
	else
		echo "$NOT_INSTALLED"
	fi
}

cursor_is_installed() {
	command -v agent >/dev/null 2>&1 || command -v cursor >/dev/null 2>&1
}

check_cursor_cli() {
	local installed available action upgradable=0
	installed="$(cursor_installed_version)"
	if cursor_is_installed; then
		if command -v agent >/dev/null 2>&1; then
			available="latest (via agent update)"
		else
			available="latest (via cursor update)"
		fi
		action="upgrade"
		upgradable=1
	else
		available="—"
		action="skip"
	fi
	printf '%s|%s|%s|%s\n' "Cursor CLI" "$installed" "$available" "$action"
	[[ $upgradable -eq 1 ]]
}

upgrade_cursor_cli() {
	if command -v agent >/dev/null 2>&1; then
		agent update
	elif command -v cursor >/dev/null 2>&1; then
		cursor update
	else
		_msg "  Cursor CLI not installed, skipping"
	fi
}

# --- Codex CLI ---
codex_installed_version() {
	if command -v codex >/dev/null 2>&1; then
		codex --version 2>/dev/null | head -n1 || echo "installed"
	else
		echo "$NOT_INSTALLED"
	fi
}

codex_available_version() {
	if ! command -v npm >/dev/null 2>&1; then
		echo "—"
		return
	fi
	npm view @openai/codex version 2>/dev/null || echo "—"
}

check_codex_cli() {
	local installed available action upgradable=0
	installed="$(codex_installed_version)"
	if [[ "$installed" == "$NOT_INSTALLED" ]]; then
		available="—"
		action="skip"
	else
		available="$(codex_available_version)"
		if [[ "$available" != "—" && "$installed" != *"${available}"* ]]; then
			action="upgrade"
			upgradable=1
		else
			action="up to date"
		fi
	fi
	printf '%s|%s|%s|%s\n' "Codex CLI" "$installed" "$available" "$action"
	[[ $upgradable -eq 1 ]]
}

upgrade_codex_cli() {
	if command -v codex >/dev/null 2>&1 && command -v npm >/dev/null 2>&1; then
		npm i -g @openai/codex@latest
	else
		_msg "  Codex CLI or npm not installed, skipping"
	fi
}

# --- Claude CLI ---
claude_installed_version() {
	if command -v claude >/dev/null 2>&1; then
		claude --version 2>/dev/null | head -n1 || echo "installed"
	else
		echo "$NOT_INSTALLED"
	fi
}

check_claude_cli() {
	local installed available action upgradable=0
	installed="$(claude_installed_version)"
	if [[ "$installed" == "$NOT_INSTALLED" ]]; then
		available="—"
		action="skip"
	else
		available="latest (via claude update)"
		action="upgrade"
		upgradable=1
	fi
	printf '%s|%s|%s|%s\n' "Claude CLI" "$installed" "$available" "$action"
	[[ $upgradable -eq 1 ]]
}

upgrade_claude_cli() {
	if command -v claude >/dev/null 2>&1; then
		claude update
	else
		_msg "  Claude CLI not installed, skipping"
	fi
}

# --- Copilot CLI ---
copilot_installed_version() {
	if command -v copilot >/dev/null 2>&1; then
		copilot --version 2>/dev/null | head -n1 || echo "installed"
	elif [[ -x "$HOME/.local/bin/copilot" ]]; then
		"$HOME/.local/bin/copilot" --version 2>/dev/null | head -n1 || echo "installed"
	else
		echo "$NOT_INSTALLED"
	fi
}

copilot_is_installed() {
	command -v copilot >/dev/null 2>&1 || [[ -x "$HOME/.local/bin/copilot" ]]
}

check_copilot_cli() {
	local installed available action upgradable=0
	installed="$(copilot_installed_version)"
	if copilot_is_installed; then
		available="latest (via copilot update)"
		action="upgrade"
		upgradable=1
	else
		available="—"
		action="skip"
	fi
	printf '%s|%s|%s|%s\n' "Copilot CLI" "$installed" "$available" "$action"
	[[ $upgradable -eq 1 ]]
}

upgrade_copilot_cli() {
	if copilot_is_installed; then
		copilot update
	else
		_msg "  Copilot CLI not installed, skipping"
	fi
}

# --- lazygit ---
lazygit_installed_version() {
	if command -v lazygit >/dev/null 2>&1; then
		lazygit --version 2>/dev/null | grep -oP 'version=\K[0-9.]+' | head -n1 ||
			lazygit --version 2>/dev/null | head -n1 || echo "installed"
	else
		echo "$NOT_INSTALLED"
	fi
}

check_lazygit() {
	local installed latest available action upgradable=0
	installed="$(lazygit_installed_version)"
	if [[ "$installed" == "$NOT_INSTALLED" ]]; then
		available="—"
		action="skip"
	else
		latest="$(_github_latest_version jesseduffield/lazygit || true)"
		available="${latest:-unknown}"
		if [[ -n "$latest" ]] && _version_gt "$latest" "$installed"; then
			action="upgrade"
			upgradable=1
		else
			action="up to date"
		fi
	fi
	printf '%s|%s|%s|%s\n' "lazygit" "$installed" "$available" "$action"
	[[ $upgradable -eq 1 ]]
}

install_lazygit_from_github() {
	command -v curl >/dev/null 2>&1 || {
		_err "  curl required for lazygit install."
		return 1
	}
	command -v tar >/dev/null 2>&1 || {
		_err "  tar required for lazygit install."
		return 1
	}

	local ver tmp
	ver="$(_github_latest_version jesseduffield/lazygit)"
	[[ -n "$ver" ]] || {
		_err "  Could not determine lazygit version."
		return 1
	}

	tmp="$(mktemp -d)"
	trap "rm -rf '${tmp}'" RETURN
	local tarball="lazygit_${ver}_Linux_x86_64.tar.gz"
	curl -fsSL -o "$tmp/$tarball" \
		"https://github.com/jesseduffield/lazygit/releases/download/v${ver}/${tarball}"
	curl -fsSL -o "$tmp/checksums.txt" \
		"https://github.com/jesseduffield/lazygit/releases/download/v${ver}/checksums.txt"
	if ! _verify_github_tarball_checksum "$tmp" "$tarball" checksums.txt; then
		_err "  lazygit checksum verification failed."
		return 1
	fi
	tar -C "$tmp" -xzf "$tmp/$tarball" lazygit
	sudo install -m 0755 "$tmp/lazygit" /usr/local/bin/lazygit
	rm -rf "$tmp"
	trap - RETURN
	_msg "  lazygit v${ver} installed"
}

upgrade_lazygit() {
	if ! command -v lazygit >/dev/null 2>&1; then
		_msg "  lazygit not installed, skipping"
		return 0
	fi
	local installed latest
	installed="$(lazygit_installed_version)"
	latest="$(_github_latest_version jesseduffield/lazygit || true)"
	if [[ -n "$latest" && -n "$installed" ]] && _version_gt "$latest" "$installed"; then
		install_lazygit_from_github
	else
		_msg "  lazygit already up to date (${installed})"
	fi
}

# --- lazydocker ---
lazydocker_installed_version() {
	if command -v lazydocker >/dev/null 2>&1; then
		lazydocker --version 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -n1 ||
			echo "$NOT_INSTALLED"
	else
		echo "$NOT_INSTALLED"
	fi
}

check_lazydocker() {
	local installed latest available action upgradable=0
	installed="$(lazydocker_installed_version)"
	if [[ "$installed" == "$NOT_INSTALLED" ]]; then
		available="—"
		action="skip"
	else
		latest="$(_github_latest_version jesseduffield/lazydocker || true)"
		available="${latest:-unknown}"
		if [[ -n "$latest" ]] && _version_gt "$latest" "$installed"; then
			action="upgrade"
			upgradable=1
		else
			action="up to date"
		fi
	fi
	printf '%s|%s|%s|%s\n' "lazydocker" "$installed" "$available" "$action"
	[[ $upgradable -eq 1 ]]
}

install_lazydocker_from_github() {
	command -v curl >/dev/null 2>&1 || {
		_err "  curl required for lazydocker install."
		return 1
	}
	command -v tar >/dev/null 2>&1 || {
		_err "  tar required for lazydocker install."
		return 1
	}

	local ver tmp
	ver="$(_github_latest_version jesseduffield/lazydocker)"
	[[ -n "$ver" ]] || {
		_err "  Could not determine lazydocker version."
		return 1
	}

	tmp="$(mktemp -d)"
	trap "rm -rf '${tmp}'" RETURN
	local tarball="lazydocker_${ver}_Linux_x86_64.tar.gz"
	curl -fsSL -o "$tmp/$tarball" \
		"https://github.com/jesseduffield/lazydocker/releases/download/v${ver}/${tarball}"
	curl -fsSL -o "$tmp/checksums.txt" \
		"https://github.com/jesseduffield/lazydocker/releases/download/v${ver}/checksums.txt"
	if ! _verify_github_tarball_checksum "$tmp" "$tarball" checksums.txt; then
		_err "  lazydocker checksum verification failed."
		return 1
	fi
	tar -C "$tmp" -xzf "$tmp/$tarball"

	if [[ ! -f "$tmp/lazydocker" ]]; then
		local binpath
		binpath="$(find "$tmp" -maxdepth 3 -type f -name lazydocker | head -n1 || true)"
		[[ -n "$binpath" ]] && cp "$binpath" "$tmp/lazydocker"
	fi

	sudo install -m 0755 "$tmp/lazydocker" /usr/local/bin/lazydocker
	rm -rf "$tmp"
	trap - RETURN
	_msg "  lazydocker v${ver} installed"
}

upgrade_lazydocker() {
	if ! command -v lazydocker >/dev/null 2>&1; then
		_msg "  lazydocker not installed, skipping"
		return 0
	fi
	local installed latest
	installed="$(lazydocker_installed_version)"
	latest="$(_github_latest_version jesseduffield/lazydocker || true)"
	if [[ -n "$latest" && -n "$installed" ]] && _version_gt "$latest" "$installed"; then
		install_lazydocker_from_github
	else
		_msg "  lazydocker already up to date (${installed})"
	fi
}

# --- Node.js (nvm) — opt-in ---
node_installed_version() {
	_load_nvm
	if command -v node >/dev/null 2>&1; then
		node --version 2>/dev/null | tr -d 'v'
	else
		echo "$NOT_INSTALLED"
	fi
}

node_lts_version() {
	_load_nvm
	if command -v nvm >/dev/null 2>&1; then
		nvm version-remote --lts 2>/dev/null | tr -d 'v' || echo "—"
	else
		echo "—"
	fi
}

check_node() {
	local installed available action upgradable=0
	installed="$(node_installed_version)"
	available="$(node_lts_version)"
	if [[ "$installed" == "$NOT_INSTALLED" ]]; then
		action="skip"
	elif [[ "$available" != "—" ]] && _version_gt "$available" "$installed"; then
		action="upgrade (--all)"
		upgradable=1
	else
		action="up to date"
	fi
	printf '%s|%s|%s|%s\n' "Node.js (nvm)" "$installed" "$available" "$action"
	[[ $upgradable -eq 1 ]]
}

upgrade_node() {
	_load_nvm
	if ! command -v nvm >/dev/null 2>&1; then
		_msg "  nvm not installed, skipping Node.js upgrade"
		return 0
	fi
	nvm install --lts
	nvm alias default 'lts/*'
}

# --- Go (asdf) — opt-in ---
go_installed_version() {
	if command -v asdf >/dev/null 2>&1; then
		local ver
		ver="$(asdf current golang 2>/dev/null | awk '$1=="golang" {print $2; exit}')"
		if [[ -n "$ver" ]]; then
			echo "$ver"
		else
			echo "$NOT_INSTALLED"
		fi
	elif command -v go >/dev/null 2>&1; then
		go version 2>/dev/null | grep -oP 'go\K[0-9.]+' | head -n1 || echo "installed"
	else
		echo "$NOT_INSTALLED"
	fi
}

go_latest_version() {
	if command -v asdf >/dev/null 2>&1; then
		asdf latest golang 2>/dev/null || echo "—"
	else
		echo "—"
	fi
}

check_go() {
	local installed available action upgradable=0
	installed="$(go_installed_version)"
	available="$(go_latest_version)"
	if [[ "$installed" == "$NOT_INSTALLED" ]]; then
		action="skip"
	elif [[ "$available" != "—" ]] && _version_gt "$available" "$installed"; then
		action="upgrade (--all)"
		upgradable=1
	else
		action="up to date"
	fi
	printf '%s|%s|%s|%s\n' "Go (asdf)" "$installed" "$available" "$action"
	[[ $upgradable -eq 1 ]]
}

upgrade_go() {
	if ! command -v asdf >/dev/null 2>&1; then
		_msg "  asdf not installed, skipping Go upgrade"
		return 0
	fi
	asdf install golang latest
	asdf set -u golang latest
}

# --- Monaspace fonts — opt-in ---
monaspace_installed_version() {
	local font_dir="$HOME/.local/share/fonts/monaspace"
	if [[ -d "$font_dir" ]] && compgen -G "${font_dir}/*.otf" >/dev/null 2>&1; then
		if [[ -f "${font_dir}/.version" ]]; then
			cat "${font_dir}/.version"
		else
			echo "installed"
		fi
	else
		echo "$NOT_INSTALLED"
	fi
}

monaspace_latest_version() {
	_github_latest_version githubnext/monaspace || echo "—"
}

check_monaspace() {
	local installed available action upgradable=0
	installed="$(monaspace_installed_version)"
	available="$(monaspace_latest_version)"
	if [[ "$installed" == "$NOT_INSTALLED" ]]; then
		action="skip"
	elif [[ "$available" != "—" && "$installed" != "$available" ]]; then
		action="upgrade (--all)"
		upgradable=1
	else
		action="up to date"
	fi
	printf '%s|%s|%s|%s\n' "Monaspace fonts" "$installed" "$available" "$action"
	[[ $upgradable -eq 1 ]]
}

install_monaspace_fonts() {
	local font_dir="$HOME/.local/share/fonts/monaspace"
	command -v curl >/dev/null 2>&1 || {
		_err "  curl required for Monaspace install."
		return 1
	}
	command -v unzip >/dev/null 2>&1 || {
		_err "  unzip required for Monaspace install."
		return 1
	}

	local ver tmp
	ver="$(monaspace_latest_version)"
	[[ -n "$ver" && "$ver" != "—" ]] || {
		_err "  Could not determine Monaspace version."
		return 1
	}

	tmp="$(mktemp -d)"
	trap "rm -rf '${tmp}'" RETURN
	local zip="monaspace-nerdfonts-v${ver}.zip"
	local url="https://github.com/githubnext/monaspace/releases/download/v${ver}/${zip}"
	if ! curl -fsSL -o "$tmp/monaspace-nerdfonts.zip" "$url"; then
		_err "  Monaspace download failed (${url})."
		return 1
	fi
	if ! unzip -qo "$tmp/monaspace-nerdfonts.zip" -d "$tmp/monaspace"; then
		_err "  Monaspace unzip failed."
		return 1
	fi

	mkdir -p "$font_dir"
	local otf_count=0
	while IFS= read -r -d '' otf; do
		cp "$otf" "$font_dir/"
		otf_count=$((otf_count + 1))
	done < <(find "$tmp/monaspace" -name '*.otf' -print0)
	if [[ $otf_count -eq 0 ]]; then
		_err "  No .otf files found in Monaspace archive."
		return 1
	fi
	printf '%s\n' "$ver" >"${font_dir}/.version"

	fc-cache -f 2>/dev/null || true
	rm -rf "$tmp"
	trap - RETURN
	_msg "  Monaspace Nerd Fonts ${ver} installed"
}

upgrade_monaspace() {
	install_monaspace_fonts
}

# --- dotfiles repo ---
dotfiles_repo_status() {
	if ! command -v git >/dev/null 2>&1; then
		echo "$NOT_INSTALLED|—|skip"
		return
	fi
	local branch local_rev remote_rev behind=0
	branch="$(git -C "$DOTFILES_DIR" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")"
	local_rev="$(git -C "$DOTFILES_DIR" rev-parse --short HEAD 2>/dev/null || echo "unknown")"
	remote_rev="$(git -C "$DOTFILES_DIR" ls-remote --heads origin "$branch" 2>/dev/null | awk '{print $1}' | head -n1)"
	local installed="${branch}@${local_rev}"
	local available="—"
	local action="up to date"
	if [[ -n "$remote_rev" && "$remote_rev" != "$(git -C "$DOTFILES_DIR" rev-parse HEAD 2>/dev/null)" ]]; then
		behind="$(git -C "$DOTFILES_DIR" rev-list --count HEAD.."origin/${branch}" 2>/dev/null || echo "?")"
		if [[ "$behind" == "?" ]]; then
			available="update on origin"
		else
			available="${behind} commit(s) behind"
		fi
		action="pull + restow"
	fi
	printf '%s|%s|%s|%s\n' "dotfiles repo" "$installed" "$available" "$action"
	[[ "$action" != "up to date" ]]
}

# --- Report helpers ---
CHECK_FUNCS=(
	check_apt
	check_cursor_cli
	check_codex_cli
	check_claude_cli
	check_copilot_cli
	check_lazygit
	check_lazydocker
	check_node
	check_go
	check_monaspace
	dotfiles_repo_status
)

_color_action() {
	local action="$1"
	case "$action" in
	up\ to\ date | skip) printf '%s%s%s' "$C_GREEN" "$action" "$C_RESET" ;;
	upgrade*) printf '%s%s%s' "$C_YELLOW" "$action" "$C_RESET" ;;
	pull*) printf '%s%s%s' "$C_CYAN" "$action" "$C_RESET" ;;
	*) printf '%s' "$action" ;;
	esac
}

_color_result() {
	local result="$1"
	case "$result" in
	ok | installed | configured) printf '%s%s%s' "$C_GREEN" "$result" "$C_RESET" ;;
	failed) printf '%s%s%s' "$C_RED" "$result" "$C_RESET" ;;
	skipped*) printf '%s%s%s' "$C_DIM" "$result" "$C_RESET" ;;
	*) printf '%s' "$result" ;;
	esac
}

_collect_check_rows() {
	local -a rows=()
	local fn row
	for fn in "${CHECK_FUNCS[@]}"; do
		row="$("$fn" || true)"
		rows+=("$row")
	done
	printf '%s\n' "${rows[@]}"
}

print_report_table() {
	local -a rows=()
	local row component installed available action
	local upgrade_count=0

	mapfile -t rows < <(_collect_check_rows)

	for row in "${rows[@]}"; do
		IFS='|' read -r _ _ _ action <<<"$row"
		case "$action" in
		upgrade | pull*) ((++upgrade_count)) ;;
		upgrade*) ((++upgrade_count)) ;;
		esac
	done

	printf '\n%sUpgrade report%s\n' "$C_BOLD" "$C_RESET"
	printf '%-18s | %-28s | %-22s | %s\n' "component" "installed" "available" "action"
	printf '%s\n' "-------------------+------------------------------+------------------------+----------"

	for row in "${rows[@]}"; do
		IFS='|' read -r component installed available action <<<"$row"
		printf '%-18s | %-28s | %-22s | ' "$component" "$installed" "$available"
		_color_action "$action"
		printf '\n'
	done

	printf '\n'
	if [[ $upgrade_count -eq 0 ]]; then
		printf '%s0 upgrades available%s — everything looks current.\n' "$C_GREEN" "$C_RESET"
	else
		printf '%s%d upgrade%s available%s — run `%sdotfiles upgrade%s` to apply.\n' \
			"$C_YELLOW" "$upgrade_count" "$([[ $upgrade_count -eq 1 ]] && echo '' || echo 's')" "$C_RESET" \
			"$C_BOLD" "$C_RESET"
	fi
}

print_upgrade_summary() {
	local upgrade_all="${1:-false}"
	local -a rows=()
	local row component installed available _action result
	local ok_count=0 fail_count=0

	mapfile -t rows < <(_collect_check_rows)

	printf '\n%sUpgrade summary%s\n' "$C_BOLD" "$C_RESET"
	printf '%-18s | %-28s | %-22s | %s\n' "component" "installed" "available" "result"
	printf '%s\n' "-------------------+------------------------------+------------------------+----------"

	for row in "${rows[@]}"; do
		IFS='|' read -r component installed available _action <<<"$row"
		result="${UPGRADE_STEP_RESULT[$component]:-}"
		if [[ -z "$result" ]]; then
			case "$component" in
			"Node.js (nvm)" | "Go (asdf)" | "Monaspace fonts")
				if [[ "$upgrade_all" == true ]]; then
					result="skipped"
				else
					result="skipped (--all)"
				fi
				;;
			*) result="—" ;;
			esac
		fi
		case "$result" in
		ok) ((++ok_count)) ;;
		failed) ((++fail_count)) ;;
		esac
		printf '%-18s | %-28s | %-22s | ' "$component" "$installed" "$available"
		_color_result "$result"
		printf '\n'
	done

	printf '\n'
	if [[ $fail_count -eq 0 ]]; then
		printf '%sUpgrade finished%s — %d step(s) ok' "$C_GREEN" "$C_RESET" "$ok_count"
		[[ "$upgrade_all" != true ]] && printf ' (opt-in components skipped; use --all)'
		printf '.\n'
	else
		printf '%sUpgrade finished with %d failure(s)%s — see log above.\n' "$C_YELLOW" "$fail_count" "$C_RESET"
	fi
}

print_status_table() {
	local title="${1:-Status summary}"
	local -a rows=()
	local row component installed available action

	mapfile -t rows < <(_collect_check_rows)

	printf '\n%s%s%s\n' "$C_BOLD" "$title" "$C_RESET"
	printf '%-18s | %-28s | %-22s | %s\n' "component" "installed" "available" "status"
	printf '%s\n' "-------------------+------------------------------+------------------------+----------"

	for row in "${rows[@]}"; do
		IFS='|' read -r component installed available action <<<"$row"
		printf '%-18s | %-28s | %-22s | ' "$component" "$installed" "$available"
		_color_action "$action"
		printf '\n'
	done
	printf '\n'
}

# --- IDE extensions ---
EXT_ALL_TARGETS=(vscode-wsl cursor-wsl vscode-win cursor-win)
_EXT_ENUM_METHOD=""
_EXT_ENUM_DIR=""

_ext_discover_win_user_dir() {
	local user_dir base
	for user_dir in /mnt/c/Users/*/; do
		[[ -d "$user_dir" ]] || continue
		base="$(basename "$user_dir")"
		case "$base" in
		Public | Default | 'Default User' | 'All Users') continue ;;
		esac
		if [[ -d "${user_dir}.vscode" || -d "${user_dir}.cursor" ]]; then
			printf '%s\n' "${user_dir%/}"
			return 0
		fi
	done
	for user_dir in /mnt/c/Users/*/; do
		[[ -d "$user_dir" ]] || continue
		base="$(basename "$user_dir")"
		case "$base" in
		Public | Default | 'Default User' | 'All Users') continue ;;
		esac
		printf '%s\n' "${user_dir%/}"
		return 0
	done
	return 1
}

_ext_target_platform() {
	case "$1" in
	vscode-wsl | cursor-wsl) printf 'wsl\n' ;;
	vscode-win | cursor-win) printf 'win\n' ;;
	esac
}

_ext_target_label() {
	case "$1" in
	vscode-wsl) printf 'VS Code (WSL)\n' ;;
	cursor-wsl) printf 'Cursor (WSL)\n' ;;
	vscode-win) printf 'VS Code (Windows)\n' ;;
	cursor-win) printf 'Cursor (Windows)\n' ;;
	*) printf '%s\n' "$1" ;;
	esac
}

_ext_get_extensions_dir() {
	local target="$1"
	local win_user
	case "$target" in
	vscode-wsl) printf '%s\n' "${HOME}/.vscode-server/extensions" ;;
	cursor-wsl) printf '%s\n' "${HOME}/.cursor-server/extensions" ;;
	vscode-win)
		win_user="$(_ext_discover_win_user_dir || true)"
		[[ -n "$win_user" ]] && printf '%s\n' "${win_user}/.vscode/extensions"
		;;
	cursor-win)
		win_user="$(_ext_discover_win_user_dir || true)"
		[[ -n "$win_user" ]] && printf '%s\n' "${win_user}/.cursor/extensions"
		;;
	esac
}

_ext_find_wsl_cli() {
	local kind="$1"
	local bin
	case "$kind" in
	code) bin="code" ;;
	cursor) bin="cursor" ;;
	*) return 1 ;;
	esac
	if command -v "$bin" >/dev/null 2>&1; then
		command -v "$bin"
		return 0
	fi
	return 1
}

_ext_find_win_cli() {
	local kind="$1"
	local candidate
	local -a candidates=()
	case "$kind" in
	code)
		candidates=(
			"/mnt/c/Program Files/Microsoft VS Code/bin/code.cmd"
			"/mnt/c/Program Files (x86)/Microsoft VS Code/bin/code.cmd"
		)
		;;
	cursor)
		candidates=(
			"/mnt/c/Program Files/cursor/resources/app/bin/cursor.cmd"
			"/mnt/c/Program Files/Cursor/resources/app/bin/cursor.cmd"
		)
		;;
	*) return 1 ;;
	esac
	for candidate in "${candidates[@]}"; do
		[[ -f "$candidate" ]] && {
			printf '%s\n' "$candidate"
			return 0
		}
	done
	local win_user local_app
	win_user="$(_ext_discover_win_user_dir || true)"
	if [[ -n "$win_user" ]]; then
		case "$kind" in
		code)
			local_app="${win_user}/AppData/Local/Programs/Microsoft VS Code/bin/code.cmd"
			;;
		cursor)
			local_app="${win_user}/AppData/Local/Programs/cursor/resources/app/bin/cursor.cmd"
			local_app_alt="${win_user}/AppData/Local/Programs/Cursor/resources/app/bin/cursor.cmd"
			[[ -f "$local_app_alt" ]] && {
				printf '%s\n' "$local_app_alt"
				return 0
			}
			;;
		esac
		[[ -f "$local_app" ]] && {
			printf '%s\n' "$local_app"
			return 0
		}
	fi
	return 1
}

_ext_find_cli() {
	local target="$1"
	case "$target" in
	vscode-wsl) _ext_find_wsl_cli code ;;
	cursor-wsl) _ext_find_wsl_cli cursor ;;
	vscode-win) _ext_find_win_cli code ;;
	cursor-win) _ext_find_win_cli cursor ;;
	*) return 1 ;;
	esac
}

_ext_win_to_ps_path() {
	local wsl_path="$1"
	if command -v wslpath >/dev/null 2>&1; then
		wslpath -w "$wsl_path"
	else
		# Fallback: /mnt/c/... -> C:\...
		local drive rest
		if [[ "$wsl_path" =~ ^/mnt/([a-zA-Z])/(.*)$ ]]; then
			drive="$(printf '%s' "${BASH_REMATCH[1]}" | tr '[:lower:]' '[:upper:]')"
			rest="${BASH_REMATCH[2]//\//\\}"
			printf '%s:\\%s\n' "$drive" "$rest"
		else
			printf '%s\n' "$wsl_path"
		fi
	fi
}

_ext_run_win_cli() {
	local cli_wsl="$1"
	shift
	local ps_cli arg args=()
	ps_cli="$(_ext_win_to_ps_path "$cli_wsl")"
	ps_cli="${ps_cli//\'/\'\'}"
	for arg in "$@"; do
		args+=("'${arg//\'/\'\'}'")
	done
	powershell.exe -NoProfile -Command "& '${ps_cli}' ${args[*]}"
}

_ext_run_cli() {
	local target="$1"
	local cli="$2"
	shift 2
	case "$(_ext_target_platform "$target")" in
	wsl) "$cli" "$@" ;;
	win) _ext_run_win_cli "$cli" "$@" ;;
	esac
}

_ext_strip_platform_suffix() {
	local name="$1"
	local suffix changed=true
	local -a suffixes=(
		universal linux-x64 linux-arm64 linux-armhf
		win32-x64 win32-arm64 alpine-x64 alpine-arm64 darwin-x64 darwin-arm64
	)
	while [[ "$changed" == true ]]; do
		changed=false
		for suffix in "${suffixes[@]}"; do
			if [[ "$name" == *"-${suffix}" ]]; then
				name="${name%-"${suffix}"}"
				changed=true
			fi
		done
	done
	printf '%s' "$name"
}

_ext_parse_folder() {
	local folder="$1"
	local stripped id ver
	stripped="$(_ext_strip_platform_suffix "$folder")"
	if [[ "$stripped" =~ ^(.+)-([0-9].*)$ ]]; then
		id="${BASH_REMATCH[1]}"
		ver="${BASH_REMATCH[2]}"
		printf '%s@%s\n' "$id" "$ver"
	fi
}

_ext_disk_list() {
	local dir="$1"
	local folder base id_ver id ver
	declare -A best=()
	if [[ ! -d "$dir" ]]; then
		return 0
	fi
	for folder in "$dir"/*/; do
		[[ -d "$folder" ]] || continue
		base="$(basename "$folder")"
		[[ "$base" == .* ]] && continue
		id_ver="$(_ext_parse_folder "$base")"
		[[ -z "$id_ver" ]] && continue
		id="${id_ver%%@*}"
		ver="${id_ver#*@}"
		if [[ -z "${best[$id]:-}" ]] || _version_gt "$ver" "${best[$id]}"; then
			best[$id]="$ver"
		fi
	done
	local key
	for key in "${!best[@]}"; do
		printf '%s@%s\n' "$key" "${best[$key]}"
	done | sort
}

_ext_cli_list() {
	local target="$1"
	local cli="$2"
	local output ext_dir
	output="$(_ext_run_cli "$target" "$cli" --list-extensions --show-versions 2>/dev/null || true)"
	if [[ -n "$output" ]]; then
		printf '%s\n' "$output" | sed '/^[[:space:]]*$/d' | sort -u
		return 0
	fi
	ext_dir="$(_ext_get_extensions_dir "$target")"
	if [[ -n "$ext_dir" && -d "$ext_dir" ]]; then
		output="$(_ext_run_cli "$target" "$cli" --extensions-dir "$ext_dir" --list-extensions --show-versions 2>/dev/null || true)"
		if [[ -n "$output" ]]; then
			printf '%s\n' "$output" | sed '/^[[:space:]]*$/d' | sort -u
			return 0
		fi
	fi
	return 1
}

_ext_list_extensions() {
	local target="$1"
	local cli method dir list
	_EXT_ENUM_DIR="$(_ext_get_extensions_dir "$target")"
	_EXT_ENUM_METHOD="disk"
	method="disk"

	if cli="$(_ext_find_cli "$target" 2>/dev/null || true)" && [[ -n "$cli" ]]; then
		if list="$(_ext_cli_list "$target" "$cli" 2>/dev/null || true)" && [[ -n "$list" ]]; then
			method="cli"
			_EXT_ENUM_METHOD="$method"
			printf '%s\n' "$list"
			return 0
		fi
	fi

	dir="$_EXT_ENUM_DIR"
	if [[ -z "$dir" || ! -d "$dir" ]]; then
		_warn "Extensions dir not found for ${target}: ${dir:-unknown}"
		return 0
	fi
	_EXT_ENUM_METHOD="$method"
	_ext_disk_list "$dir"
}

_ext_obsolete_note() {
	local dir="$1"
	local obsolete_file count
	if [[ ! -d "$dir" ]]; then
		printf 'extensions dir missing\n'
		return
	fi
	obsolete_file="${dir}/.obsolete"
	if [[ -f "$obsolete_file" ]]; then
		count="$(wc -l <"$obsolete_file" | tr -d ' ')"
		printf '%s stale entries in .obsolete\n' "$count"
	else
		printf 'no .obsolete file\n'
	fi
}

_ext_backup_file() {
	printf '%s/extensions/%s.txt\n' "$DOTFILES_DIR" "$1"
}

_ext_manifest_file() {
	printf '%s/extensions/manifest.json\n' "$DOTFILES_DIR"
}

_ext_write_manifest() {
	local ts="$1"
	shift
	local manifest
	manifest="$(_ext_manifest_file)"
	mkdir -p "$(dirname "$manifest")"
	if ! command -v python3 >/dev/null 2>&1; then
		_warn "python3 not found; skipping manifest.json update"
		return 0
	fi
	MANIFEST_PATH="$manifest" MANIFEST_TS="$ts" MANIFEST_ENTRIES="$*" python3 - <<'PY'
import json, os, sys
from pathlib import Path

manifest_path = Path(os.environ["MANIFEST_PATH"])
ts = os.environ["MANIFEST_TS"]
entries_raw = os.environ.get("MANIFEST_ENTRIES", "")

data = {"updated": ts, "targets": {}}
if manifest_path.is_file():
    try:
        data = json.loads(manifest_path.read_text())
    except json.JSONDecodeError:
        pass
data["updated"] = ts
if "targets" not in data or not isinstance(data["targets"], dict):
    data["targets"] = {}

for chunk in entries_raw.split("|||"):
    if not chunk:
        continue
    parts = chunk.split("|", 3)
    if len(parts) < 4:
        continue
    target, count, method, ext_file = parts
    data["targets"][target] = {
        "count": int(count),
        "method": method,
        "file": ext_file,
    }

manifest_path.parent.mkdir(parents=True, exist_ok=True)
manifest_path.write_text(json.dumps(data, indent=2) + "\n")
PY
}

_ext_resolve_targets() {
	local arg="${1:-all}"
	case "$arg" in
	all) printf '%s\n' "${EXT_ALL_TARGETS[@]}" ;;
	vscode-wsl | cursor-wsl | vscode-win | cursor-win) printf '%s\n' "$arg" ;;
	*)
		_err "Unknown extension target: $arg (expected: vscode-wsl, cursor-wsl, vscode-win, cursor-win, all)"
		return 1
		;;
	esac
}

_ext_read_backup_lines() {
	local file="$1"
	if [[ ! -f "$file" ]]; then
		return 1
	fi
	grep -v '^[[:space:]]*$' "$file" | grep -v '^#' | sort -u
}

_ext_parse_ext_line() {
	local line="$1"
	_EXT_PARSE_ID="${line%%@*}"
	if [[ "$line" == *@* ]]; then
		_EXT_PARSE_VER="${line#*@}"
	else
		_EXT_PARSE_VER=""
	fi
}

_ext_install_extension() {
	local target="$1"
	local ext_line="$2"
	local cli
	cli="$(_ext_find_cli "$target" 2>/dev/null || true)"
	if [[ -z "$cli" ]]; then
		_err "  CLI not found for ${target}; cannot install ${ext_line}"
		return 1
	fi
	_msg "  installing ${ext_line}"
	_ext_run_cli "$target" "$cli" --install-extension "$ext_line" --force
}

_ext_uninstall_extension() {
	local target="$1"
	local ext_id="$2"
	local cli
	cli="$(_ext_find_cli "$target" 2>/dev/null || true)"
	if [[ -z "$cli" ]]; then
		_err "  CLI not found for ${target}; cannot uninstall ${ext_id}"
		return 1
	fi
	_msg "  uninstalling ${ext_id}"
	_ext_run_cli "$target" "$cli" --uninstall-extension "$ext_id"
}

_ext_cmd_check() {
	local target label dir method list count obsolete list_file
	for target in "$@"; do
		label="$(_ext_target_label "$target")"
		dir="$(_ext_get_extensions_dir "$target")"
		list_file="$(mktemp)"
		_ext_list_extensions "$target" >"$list_file"
		list="$(<"$list_file")"
		rm -f "$list_file"
		method="${_EXT_ENUM_METHOD:-disk}"
		count="$(printf '%s\n' "$list" | sed '/^[[:space:]]*$/d' | wc -l | tr -d ' ')"
		obsolete="$(_ext_obsolete_note "${dir:-missing}")"
		printf '\n%s=== %s (%s) ===%s\n' "$C_BOLD" "$label" "$target" "$C_RESET"
		printf '  count:      %s\n' "$count"
		printf '  method:     %s\n' "$method"
		printf '  extensions: %s\n' "${dir:-not found}"
		printf '  stale:      %s\n' "$obsolete"
	done
	printf '\n'
}

_ext_cmd_backup() {
	local target list method dir count outfile manifest_entries="" ts entry list_file
	local ext_dir="${DOTFILES_DIR}/extensions"
	mkdir -p "$ext_dir"
	ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

	for target in "$@"; do
		list_file="$(mktemp)"
		_ext_list_extensions "$target" >"$list_file"
		list="$(<"$list_file")"
		rm -f "$list_file"
		method="${_EXT_ENUM_METHOD:-disk}"
		dir="${_EXT_ENUM_DIR:-$(_ext_get_extensions_dir "$target")}"
		count="$(printf '%s\n' "$list" | sed '/^[[:space:]]*$/d' | wc -l | tr -d ' ')"
		outfile="$(_ext_backup_file "$target")"
		printf '%s\n' "$list" | sed '/^[[:space:]]*$/d' | sort -u >"$outfile"
		_msg "Backed up ${count} extension(s) for ${target} (${method}) -> ${outfile}"
		entry="${target}|${count}|${method}|$(basename "$outfile")"
		if [[ -n "$manifest_entries" ]]; then
			manifest_entries="${manifest_entries}|||${entry}"
		else
			manifest_entries="$entry"
		fi
	done

	_ext_write_manifest "$ts" "$manifest_entries"
	_msg "Updated $(_ext_manifest_file)"
}

_ext_cmd_restore() {
	local prune="$1"
	shift
	local target backup_file line cli
	local -a installed_ids=()
	local -a backup_ids=()

	for target in "$@"; do
		backup_file="$(_ext_backup_file "$target")"
		if [[ ! -f "$backup_file" ]]; then
			_err "No backup file for ${target}: ${backup_file}"
			continue
		fi
		printf '\n%s=== Restoring %s ===%s\n' "$C_BOLD" "$target" "$C_RESET"
		while IFS= read -r line || [[ -n "$line" ]]; do
			[[ -z "$line" || "$line" =~ ^# ]] && continue
			_ext_install_extension "$target" "$line" || true
		done <"$backup_file"

		if [[ "$prune" == true ]]; then
			cli="$(_ext_find_cli "$target" 2>/dev/null || true)"
			if [[ -z "$cli" ]]; then
				_warn "Cannot prune ${target}: CLI not found"
				continue
			fi
			installed_ids=()
			backup_ids=()
			while IFS= read -r line; do
				_ext_parse_ext_line "$line"
				[[ -n "$_EXT_PARSE_ID" ]] && installed_ids+=("$_EXT_PARSE_ID")
			done < <(_ext_list_extensions "$target" | sed '/^[[:space:]]*$/d')
			while IFS= read -r line; do
				_ext_parse_ext_line "$line"
				[[ -n "$_EXT_PARSE_ID" ]] && backup_ids+=("$_EXT_PARSE_ID")
			done < <(_ext_read_backup_lines "$backup_file")

			local inst_id found
			for inst_id in "${installed_ids[@]}"; do
				found=false
				local bid
				for bid in "${backup_ids[@]}"; do
					if [[ "$inst_id" == "$bid" ]]; then
						found=true
						break
					fi
				done
				if [[ "$found" == false ]]; then
					_ext_uninstall_extension "$target" "$inst_id" || true
				fi
			done
		fi
	done
}

_ext_cmd_compare() {
	local target backup_file installed label
	local line id ver
	declare -A backup_ver installed_ver
	local -a only_backup=() only_installed=() drift=()

	for target in "$@"; do
		backup_file="$(_ext_backup_file "$target")"
		label="$(_ext_target_label "$target")"
		backup_ver=()
		installed_ver=()
		only_backup=()
		only_installed=()
		drift=()

		printf '\n%s=== Compare %s (%s) ===%s\n' "$C_BOLD" "$label" "$target" "$C_RESET"

		if [[ ! -f "$backup_file" ]]; then
			_warn "No backup file: ${backup_file}"
			continue
		fi

		while IFS= read -r line; do
			_ext_parse_ext_line "$line"
			[[ -n "$_EXT_PARSE_ID" ]] && backup_ver["$_EXT_PARSE_ID"]="$_EXT_PARSE_VER"
		done < <(_ext_read_backup_lines "$backup_file")

		while IFS= read -r line; do
			_ext_parse_ext_line "$line"
			[[ -n "$_EXT_PARSE_ID" ]] && installed_ver["$_EXT_PARSE_ID"]="$_EXT_PARSE_VER"
		done < <(_ext_list_extensions "$target" | sed '/^[[:space:]]*$/d')

		local key
		for key in "${!backup_ver[@]}"; do
			if [[ -z "${installed_ver[$key]:-}" ]]; then
				only_backup+=("${key}@${backup_ver[$key]}")
			elif [[ "${backup_ver[$key]}" != "${installed_ver[$key]}" ]]; then
				drift+=("${key}: backup=${backup_ver[$key]} installed=${installed_ver[$key]}")
			fi
		done
		for key in "${!installed_ver[@]}"; do
			if [[ -z "${backup_ver[$key]:-}" ]]; then
				only_installed+=("${key}@${installed_ver[$key]}")
			fi
		done

		if [[ ${#only_backup[@]} -gt 0 ]]; then
			mapfile -t only_backup < <(printf '%s\n' "${only_backup[@]}" | sort)
		fi
		if [[ ${#only_installed[@]} -gt 0 ]]; then
			mapfile -t only_installed < <(printf '%s\n' "${only_installed[@]}" | sort)
		fi
		if [[ ${#drift[@]} -gt 0 ]]; then
			mapfile -t drift < <(printf '%s\n' "${drift[@]}" | sort)
		fi

		printf '  only in backup (%d):\n' "${#only_backup[@]}"
		if [[ ${#only_backup[@]} -eq 0 ]]; then
			printf '    (none)\n'
		else
			local item
			for item in "${only_backup[@]}"; do
				printf '    %s\n' "$item"
			done
		fi

		printf '  only installed (%d):\n' "${#only_installed[@]}"
		if [[ ${#only_installed[@]} -eq 0 ]]; then
			printf '    (none)\n'
		else
			for item in "${only_installed[@]}"; do
				printf '    %s\n' "$item"
			done
		fi

		printf '  version drift (%d):\n' "${#drift[@]}"
		if [[ ${#drift[@]} -eq 0 ]]; then
			printf '    (none)\n'
		else
			for item in "${drift[@]}"; do
				printf '    %s\n' "$item"
			done
		fi
	done
	printf '\n'
}

cmd_ext_help() {
	cat <<EOF
Usage: dotfiles ext <subcommand> [target] [options]

Subcommands:
  check [target]     Report extension inventory per target (count, method, path)
  backup [target]    Write manifests to extensions/<target>.txt + manifest.json
  restore [target]   Install extensions from backup (--prune to uninstall extras)
  compare [target]   Diff installed vs backed-up extensions

Targets: vscode-wsl, cursor-wsl, vscode-win, cursor-win, all (default: all)

Examples:
  dotfiles ext check
  dotfiles ext backup cursor-wsl
  dotfiles ext restore all
  dotfiles ext restore cursor-wsl --prune
  dotfiles ext compare vscode-win
EOF
}

cmd_ext() {
	local subcmd="${1:-}"
	[[ -z "$subcmd" ]] && {
		cmd_ext_help
		return 1
	}
	shift

	local target="all"
	local prune=false

	case "$subcmd" in
	check | backup | compare)
		if [[ $# -gt 0 && "$1" != -* ]]; then
			target="$1"
			shift
		fi
		;;
	restore)
		while [[ $# -gt 0 ]]; do
			case "$1" in
			--prune) prune=true ;;
			-h | --help)
				cmd_ext_help
				return 0
				;;
			-*)
				_err "Unknown option: $1"
				cmd_ext_help
				return 1
				;;
			*)
				if [[ "$target" == "all" ]]; then
					target="$1"
				else
					_err "Unexpected argument: $1"
					cmd_ext_help
					return 1
				fi
				;;
			esac
			shift
		done
		;;
	help | -h | --help)
		cmd_ext_help
		return 0
		;;
	*)
		_err "Unknown ext subcommand: $subcmd"
		cmd_ext_help
		return 1
		;;
	esac

	if [[ $# -gt 0 ]]; then
		_err "Unexpected argument: $1"
		cmd_ext_help
		return 1
	fi

	local -a targets=()
	local t
	while IFS= read -r t; do
		[[ -n "$t" ]] && targets+=("$t")
	done < <(_ext_resolve_targets "$target" || return 1)

	case "$subcmd" in
	check) _ext_cmd_check "${targets[@]}" ;;
	backup) _ext_cmd_backup "${targets[@]}" ;;
	restore) _ext_cmd_restore "$prune" "${targets[@]}" ;;
	compare) _ext_cmd_compare "${targets[@]}" ;;
	esac
}

# --- Subcommands ---
cmd_update() {
	print_report_table
	exit 0
}

cmd_upgrade() {
	local upgrade_all=false
	local arg

	UPGRADE_STEP_RESULT=()

	for arg in "$@"; do
		case "$arg" in
		--all) upgrade_all=true ;;
		-h | --help)
			cmd_help
			return 0
			;;
		*)
			_err "Unknown option: $arg"
			_msg "Usage: dotfiles upgrade [--all]"
			return 1
			;;
		esac
	done

	_run_upgrade_step "apt packages" upgrade_apt
	_run_upgrade_step "Cursor CLI" upgrade_cursor_cli
	_run_upgrade_step "Codex CLI" upgrade_codex_cli
	_run_upgrade_step "Claude CLI" upgrade_claude_cli
	_run_upgrade_step "Copilot CLI" upgrade_copilot_cli
	_run_upgrade_step "lazygit" upgrade_lazygit
	_run_upgrade_step "lazydocker" upgrade_lazydocker

	if [[ "$upgrade_all" == true ]]; then
		_run_upgrade_step "Node.js (nvm)" upgrade_node
		_run_upgrade_step "Go (asdf)" upgrade_go
		_run_upgrade_step "Monaspace fonts" upgrade_monaspace
	else
		_msg ""
		_msg "${C_DIM}Skipping opt-in upgrades (Node.js, Go, Monaspace). Use --all to include them.${C_RESET}"
	fi

	print_upgrade_summary "$upgrade_all"
}

cmd_summary() {
	print_status_table "Status summary"
}

cmd_status() {
	printf '%s=== Installed versions ===%s\n\n' "$C_BOLD" "$C_RESET"

	printf '  %-20s %s\n' "apt:" "$(command -v apt-get >/dev/null 2>&1 && echo "available" || echo "$NOT_INSTALLED")"
	printf '  %-20s %s\n' "Cursor CLI:" "$(cursor_installed_version)"
	printf '  %-20s %s\n' "Codex CLI:" "$(codex_installed_version)"
	printf '  %-20s %s\n' "Claude CLI:" "$(claude_installed_version)"
	printf '  %-20s %s\n' "Copilot CLI:" "$(copilot_installed_version)"
	printf '  %-20s %s\n' "lazygit:" "$(lazygit_installed_version)"
	printf '  %-20s %s\n' "lazydocker:" "$(lazydocker_installed_version)"
	printf '  %-20s %s\n' "Node.js:" "$(node_installed_version)"
	printf '  %-20s %s\n' "Go:" "$(go_installed_version)"
	printf '  %-20s %s\n' "Monaspace:" "$(monaspace_installed_version)"

	printf '\n%s=== Dotfiles repo ===%s\n' "$C_BOLD" "$C_RESET"
	if command -v git >/dev/null 2>&1; then
		git -C "$DOTFILES_DIR" status -sb
	else
		_msg "git $NOT_INSTALLED"
	fi
}

cmd_restow() {
	if ! command -v stow >/dev/null 2>&1; then
		_err "Error: 'stow' is not installed."
		exit 1
	fi
	stow --dir "$DOTFILES_DIR" --target "$HOME" --restow bash bin readline
	_msg "Dotfiles restowed."
}

cmd_self() {
	if ! command -v git >/dev/null 2>&1; then
		_err "Error: git is not installed."
		exit 1
	fi
	git -C "$DOTFILES_DIR" pull
	cmd_restow
}

cmd_menu() {
	local installer="${DOTFILES_DIR}/install.sh"
	if [[ ! -f "$installer" ]]; then
		_err "Error: install.sh not found at ${installer}"
		exit 1
	fi
	exec bash "$installer" "$@"
}

cmd_help() {
	cat <<EOF
Usage: dotfiles <command> [options]

Commands:
  menu       Boot menu (initial setup / update / extensions / agents)
  summary    Post-run status table (installed versions)
  update     Dry-run report of upgradable components (no changes)
  upgrade    Apply upgrades (apt, CLIs, GitHub tools)
             Use --all to include Node.js, Go, and Monaspace fonts
  status     Show installed versions and dotfiles git status
  restow     Re-apply stow for bash, bin, readline
  self       git pull dotfiles repo, then restow
  ext        IDE extension backup/restore (see: dotfiles ext help)
  help       Show this help

Examples:
  dotfiles menu
  dotfiles summary
  dotfiles update
  dotfiles upgrade
  dotfiles upgrade --all
  dotfiles status
  dotfiles self

Repo: ${DOTFILES_DIR}
EOF
}

main() {
	case "${1:-}" in
	menu) shift; cmd_menu "$@" ;;
	summary) cmd_summary ;;
	update) cmd_update ;;
	upgrade) shift; cmd_upgrade "$@" ;;
	status) cmd_status ;;
	restow) cmd_restow ;;
	self) cmd_self ;;
	ext) shift; cmd_ext "$@" ;;
	help | -h | --help) cmd_help ;;
	'')
		if [[ -t 1 ]]; then
			cmd_menu
		else
			cmd_help
		fi
		;;
	*)
		_err "Unknown command: $1"
		_msg ""
		cmd_help
		exit 1
		;;
	esac
}

main "$@"
