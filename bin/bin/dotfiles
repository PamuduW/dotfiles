		action="skip"
	else
		available="—"
		action="up to date"
	fi
	printf '%s|%s|%s|%s\n' "Claude CLI" "$installed" "$available" "$action"
	[[ $upgradable -eq 1 ]]
}

upgrade_claude_cli() {
